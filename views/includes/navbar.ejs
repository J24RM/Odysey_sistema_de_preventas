<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>PPG - Navbar</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    body { font-family: 'Public Sans', sans-serif; margin: 0; }
    .nav-bg { background-color: rgba(0, 120, 169, 0.1); }
    .nav-border { border-color: rgba(0, 120, 169, 0.2); }
  </style>
</head>
<body class="bg-gray-100 min-h-screen">

  <!-- NAVBAR -->
  <header class="nav-bg border-b nav-border w-full">
    <div class="w-full px-8 py-2 flex items-center gap-8">

      <!-- Logo PPG -->
      <div class="flex-shrink-0">
        <button class="relative flex items-center justify-center w-16 h-16 hover:border-[#0078A9] transition-all duration-200">
          <img src="../../public/img/ppg-logo.svg" alt="" class="w-full h-full object-contain">
        </button>
      </div>  

      <!-- Sucursal -->
      <div class="flex-shrink-0">
        <button class="flex items-center gap-2 bg-white border border-gray-300 rounded-lg px-4 py-1.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 hover:border-[#0078A9] transition-all duration-200 shadow-sm whitespace-nowrap">
          Sucursal: Jurica
          <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
      </div>

      <!-- Buscador -->
      <div class="flex-1">
        <input
          type="text"
          placeholder="Buscar Producto"
          class="w-full bg-white border border-gray-300 rounded-lg px-4 py-1.5 text-sm text-gray-600 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#0078A9] focus:border-transparent shadow-sm transition-all duration-200"
        />
      </div>

      <!-- Mis Pedidos -->
      <div class="flex-shrink-0">
        <button class="flex items-center justify-center bg-white border-2 border-gray-300 rounded-lg w-16 h-10 text-xs font-semibold text-gray-700 hover:border-[#0078A9] hover:text-[#0078A9] transition-all duration-200 leading-tight text-center whitespace-nowrap">
          Mis<br/>Pedidos
        </button>
      </div>

      <!-- Carrito  -->
      <div class="flex-shrink-0 relative">
        <button class="relative flex items-center justify-center w-10 h-10 hover:border-[#0078A9] transition-all duration-200">
          <img src="../../public/img/carrito.png" alt="">
          <span class="absolute -top-1 -right-1 bg-red-500 text-white text-[10px] font-bold rounded-full w-4 h-4 flex items-center justify-center shadow">3</span>
        </button>
      </div>

      <!-- Usuario  -->
      <div class="flex-shrink-0">
        <button class="flex items-center justify-center w-10 h-10 rounded-full border-2 border-gray-300 bg-white hover:border-[#0078A9] transition-all duration-200">
          <img src="../../public/img/iconoPerfil.png" alt="">
        </button>
      </div>

    </div>
  </header>

</body>
</html>