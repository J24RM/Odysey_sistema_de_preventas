<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/style_cliente_home.css">
    <title>Cliente Home</title>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
<%- include('../includes/_navbar') %>

<!-- Contenido principal aqui -->
<main class="client-main flex-1">
    <section class="banner">
        <div class="banner-text">
            <h2>Preventa Activa: Productos Exclusivos <span>Mundial 2026</span></h2>
        </div>
        <div class="banner-right">
            <div class="countdown-block">
                <div class="countdown-date">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                    del 1 de Mayo al 2 de Julio
                </div>
                <div class="countdown-tiles">
                    <div class="tile">
                        <div class="num">32</div>
                        <div class="lbl">Días</div>
                    </div>
                    <div class="tile">
                        <div class="num">12</div>
                        <div class="lbl">Horas</div>
                    </div>
                    <div class="tile">
                        <div class="num">45</div>
                        <div class="lbl">Min</div>
                    </div>
                    <div class="tile">
                        <div class="num">20</div>
                        <div class="lbl">Seg</div>
                    </div>
                </div>
            </div>
            <img src="/img/niñoMundial.png" alt="Mundial 2026" class="banner-illustration" onerror="this.src='https://cdn-icons-png.flaticon.com/512/33/33736.png'">
        </div>
    </section>

    <!-- Product Grid -->
    <div class="product-grid">
        <% if (productos && productos.length > 0) { %>
            <% productos.forEach(producto => { %>
                <a href="/cliente/product/<%= producto.id_producto %>" class="product-card">
                    <div class="product-img-wrap">
                        <img src="<%= producto.url_imagen || '/img/botePintura.png' %>" alt="<%= producto.nombre %>" onerror="this.src='/img/botePintura.png'">
                    </div>
                    <div class="product-name">
                        <%= producto.nombre %>
                    </div>
                    <div class="product-rating">
                        ★★★★★
                    </div>
                    <div class="product-price">
                        $ <%= producto.precio_unitario %>
                    </div>
                    <button class="btn-add-cart">agregar al carrito</button>
                </a>
            <% }) %>
        <% } else { %>
            <div class="col-span-full py-10 text-center text-gray-500">
                No se encontraron productos.
            </div>
        <% } %>
    </div>

    <div class="pagination-container">
        <a href="#" class="page-link">&lt; Anterior</a>
        <a href="#" class="page-link active">1</a>
        <a href="#" class="page-link">2</a>
        <a href="#" class="page-link">3</a>
        <span style="color:var(--text-muted); font-size: 14px; margin: 0 4px;">...</span>
        <a href="#" class="page-link">20</a>
        <a href="#" class="page-link">Siguiente &gt;</a>
    </div>
    
    <hr style="border: 0; height: 1.5px; background: #c0d1e1; margin: 40px 0;">
</main>

<%- include('../includes/_footer') %>

</body>
</html>
