<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/style_cliente_home.css">
    <title>Cliente Home</title>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">
<%- include('../includes/_navbar') %>

<!-- Contenido principal aqui -->
<main class="client-main flex-1">
    <!-- Mensaje de que se agrego producto al carrito -->
    <div id="success-container"
        class="hidden fixed top-4 left-1/2 -translate-x-1/2 z-50
          bg-blue-100 border border-blue-400 text-gray-900 mb-2
          px-6 py-3 rounded-xl shadow-md text-sm font-medium">
    </div> 


    <% const campActiva = config && config.activo; %>
    <% const timerImgSrc = (config && config.banner_general_url) ? '/uploads/' + config.banner_general_url : '/img/niñoMundial.png'; %>
    <% const nombreCamp = (config && config.nombre) ? config.nombre : 'Mundial 2026'; %>
    <% const fechaFinIso = (config && config.fecha_de_fin) ? new Date(config.fecha_de_fin).toISOString() : '2026-06-11T00:00:00.000Z'; %>
    <% if (campActiva) { %>
    <section class="banner">
        <!-- Izquierda -->
        <div class="banner-left">
            <p class="banner-tag">Preventa activa</p>
            <h2 class="banner-title">
                Productos Exclusivos<br>
                <span><%= nombreCamp %></span>
            </h2>
            <p class="banner-subtitle">Fin: <%= new Date(fechaFinIso).toLocaleDateString('es-MX', {day:'numeric', month:'long', year:'numeric'}) %></p>
        </div>
        <!-- Temporizador e imagen -->
        <div class="banner-right">
            <div class="countdown-tiles">
                <div class="tile">
                    <span id="cd-dias" class="num">--</span>
                    <span class="lbl">Días</span>
                </div>
                <div class="tile">
                    <span id="cd-hrs" class="num">--</span>
                    <span class="lbl">Hrs</span>
                </div>
                <div class="tile">
                    <span id="cd-min" class="num">--</span>
                    <span class="lbl">Min</span>
                </div>
                <div class="tile">
                    <span id="cd-seg" class="num">--</span>
                    <span class="lbl">Seg</span>
                </div>
            </div>
            <img src="<%= timerImgSrc %>" alt="<%= nombreCamp %>" class="banner-illustration" onerror="this.src='/img/botePintura.png'">
        </div>
    </section>
    <% } %>

    <!-- Grid de productos -->
    <div class="product-grid">
        <% if (productos && productos.length > 0) { %>
        <% productos.forEach((producto, index) => { %>
        <div class="product-card">
            <a href="/cliente/product/<%= producto.id_producto %>" class="product-link">
            <div class="product-img-wrap">
                <img src="/uploads/<%= producto.url_imagen || '/img/botePintura.png' %>" alt="<%= producto.nombre %>" onerror="this.src='/img/botePintura.png'">
            </div>
            <div class="product-name">
                <%= producto.nombre %>
            </div>
            <div class="product-rating">
                <% for (let i = 1; i <= 5; i++) { %>
                <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="display:inline-block;vertical-align:middle">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"
                    fill="<%= i <= Math.round(producto.promedio) ? '#FBBF24' : '#E5E7EB' %>"
                    stroke="<%= i <= Math.round(producto.promedio) ? '#F59E0B' : '#D1D5DB' %>"
                    stroke-width="1" stroke-linejoin="round"/>
                </svg>
                <% } %>
            </div>
            
            <div class="product-price">
                $ <%= producto.precio_unitario %>
            </div>
            </a>
            <hr class="border-gray-300 mb-0" />
            <div class="flex items-center justify-start gap-2 mt-4">
            <label class="text-xs font-semibold text-gray-700">Cantidad:</label>
            <div class="flex items-center border border-gray-400 rounded bg-white overflow-hidden">
                <button
                    type="button"
                    onclick="changeCantidad('<%= index %>', -1)"
                    class="px-2 py-1 text-gray-600 hover:bg-gray-100 text-sm leading-none select-none"
                >&#8722;</button>
                <input
                    id="cantidad-visible-<%= index %>"
                    type="text"
                    value="1"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    maxlength="3"
                    oninput="this.value = this.value.replace(/[^0-9]/g, ''); document.getElementById('cantidad-input-<%= index %>').value = this.value || 1;"
                    onblur="if(!this.value || this.value < 1) { this.value = 1; document.getElementById('cantidad-input-<%= index %>').value = 1; } else { document.getElementById('cantidad-input-<%= index %>').value = this.value; }"
                    class="w-10 text-xs font-semibold text-gray-700 outline-none text-center border-x border-gray-400 py-1"
                />
                <button
                    type="button"
                    onclick="changeCantidad('<%= index %>', 1)"
                    class="px-2 py-1 text-gray-600 hover:bg-gray-100 text-sm leading-none select-none"
                >&#43;</button>
            </div>
            </div>

            <form action="/cart/items" method="POST" class="mt-4">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="cantidad_ingresada" id="cantidad-input-<%= index %>" value="1">
            <input type="hidden" name="page" value="<%= page %>">
            <input type="hidden" name="search" value="<%= searchQuery || '' %>">
            <input type="hidden" name="id_producto" value="<%= producto.id_producto %>">
            <button type="submit" class="btn-add-cart">Agregar al carrito</button>
            </form>
        </div>
        <% }) %>
        <% } else { %>
        <div class="col-span-full py-10 text-center text-gray-500">
            No se encontraron productos.
        </div>
        <% } %>
    </div>

    <% if (!searchQuery && totalPages > 1) { %>
    <div class="pagination-container">
        <% if (page > 1) { %>
            <a href="/cliente/home?page=<%= page - 1 %>" class="page-link">&lt; Anterior</a>
        <% } %>

        <% for (let i = 1; i <= totalPages; i++) { %>
            <% if (i === page) { %>
                <a href="/cliente/home?page=<%= i %>" class="page-link active"><%= i %></a>
            <% } else if (i <= 3 || i > totalPages - 3 || (i > page - 2 && i < page + 2)) { %>
                <a href="/cliente/home?page=<%= i %>" class="page-link"><%= i %></a>
            <% } else if (i === 4 || i === totalPages - 3) { %>
                <span style="color:var(--text-muted); font-size: 14px; margin: 0 4px;">...</span>
            <% } %>
        <% } %>

        <% if (page < totalPages) { %>
            <a href="/cliente/home?page=<%= page + 1 %>" class="page-link">Siguiente &gt;</a>
        <% } %>
    </div>
    <% } %>
    
    <hr style="border: 0; height: 1.5px; background: #c0d1e1; margin: 40px 0;">
</main>

<%- include('../includes/_footer') %>
<script>window.CAMPANIA_FIN = '<%= fechaFinIso %>';</script>
<script>window._csrfToken = '<%= csrfToken %>';</script>
<script src="/JavaScript/home.js"></script>


</body>
</html>
