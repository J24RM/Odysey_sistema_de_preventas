<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/style_cliente_home.css">
    <title>Cliente Home</title>
</head>
<body class="bg-gray-50">
<!-- Colores
Menu vertical: #252f3d
Menu Horizontal: rgba(0, 120, 169, 0.1)
-->

<nav class="w-full flex items-center justify-between px-6 py-3 border-b border-gray-200" style="background-color: rgba(0, 120, 169, 0.1);">
    <!-- Logo -->
    <a href="/cliente/home" class="flex-shrink-0">
        <img src="/img/ppg-logo.svg" class="w-[60px]" alt="PPG">
    </a>

    <!-- Sucursal -->
    <div class="ml-6 flex-shrink-0">
        <button id="btnSucursal" data-bs-toggle="modal" data-bs-target="#modalSelector" class="bg-white border text-gray-800 border-gray-300 rounded-md px-4 py-2 text-sm font-semibold hover:bg-gray-50 transition-colors shadow-sm">
            Sucursal: Jurica
        </button>
    </div>

    <!-- Buscador centrado -->
    <form class="mx-auto w-[45%]">
        <div class="relative">
            <input type="search" class="w-full text-center border border-gray-300 rounded-md px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#0078A9] text-gray-800" placeholder="Buscar Producto" aria-label="Buscar Producto">
        </div>
    </form>

    <!-- Menu derecho -->
    <div class="flex items-center space-x-6 shrink-0">
        <a href="/cliente/mis-pedidos" class="bg-white border text-gray-800 border-gray-300 rounded-md px-4 py-2 text-sm font-semibold hover:bg-gray-50 transition-colors shadow-sm">Mis Pedidos</a>
        <a href="/cart" class="hover:opacity-80 transition-opacity">
            <img src="https://cdn-icons-png.flaticon.com/512/3144/3144456.png" class="w-[35px]" alt="Carrito">
        </a>
        <button id="btnPerfil" data-bs-toggle="modal" data-bs-target="#modalSelector" class="block hover:opacity-80 transition-opacity">
            <img src="/img/iconoPerfil.png" class="w-[40px] h-[40px] rounded-full object-cover shadow-sm border" alt="Perfil">
        </button>
    </div>
</nav>

<!-- Card de informacion -->
<div id="modalSelector" class="tw-modal hidden fixed inset-0 bg-black/50 z-50 items-center justify-center p-4">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-md max-h-[90vh] flex flex-col">
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200">
            <h5 class="text-lg font-semibold text-gray-800" id="modalTitle"></h5>
            <button class="btn-close-modal text-gray-500 hover:text-gray-700 text-3xl leading-none">&times;</button>
        </div>
        <div class="p-4 overflow-y-auto text-gray-800" id="modalBody">
        </div>
    </div>
</div>

<!-- Contenido principal aqui -->
<main class="client-main">
    <section class="banner">
        <div class="banner-text">
            <h2>Preventa Activa: Productos Exclusivos <span>Mundial 2026</span></h2>
        </div>
        <div class="banner-right">
            <div class="countdown-block">
                <div class="countdown-date">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                    del 1 de Mayo al 2 de Julio
                </div>
                <div class="countdown-tiles">
                    <div class="tile">
                        <div class="num">32</div>
                        <div class="lbl">Días</div>
                    </div>
                    <div class="tile">
                        <div class="num">12</div>
                        <div class="lbl">Horas</div>
                    </div>
                    <div class="tile">
                        <div class="num">45</div>
                        <div class="lbl">Min</div>
                    </div>
                    <div class="tile">
                        <div class="num">20</div>
                        <div class="lbl">Seg</div>
                    </div>
                </div>
            </div>
            <img src="/img/niñoMundial.png" alt="Mundial 2026" class="banner-illustration" onerror="this.src='https://cdn-icons-png.flaticon.com/512/33/33736.png'">
        </div>
    </section>

    <!-- Product Grid -->
    <div class="product-grid">
        <% for (let i = 0; i < 20; i++) { %>
            <a href="/cliente/product/<%= i + 1 %>" class="product-card">
                <div class="product-img-wrap">
                    <img src="/img/cubeta_ejemplo.png" alt="Sellador Comex" onerror="this.src='/img/botePintura.png'">
                </div>
                <div class="product-name">
                    Sellador Comex 5x1 Clásico Preparación de Superficies PPG Silicona o Poliuretano 4000 ml Sellador
                </div>
                <div class="product-rating">
                    ★★★★★
                </div>
                <div class="product-price">
                    $ 800
                </div>
                <button class="btn-add-cart">agregar al carrito</button>
            </a>
        <% } %>
    </div>

    <div class="pagination-container">
        <a href="#" class="page-link">&lt; Anterior</a>
        <a href="#" class="page-link active">1</a>
        <a href="#" class="page-link">2</a>
        <a href="#" class="page-link">3</a>
        <span style="color:var(--text-muted); font-size: 14px; margin: 0 4px;">...</span>
        <a href="#" class="page-link">20</a>
        <a href="#" class="page-link">Siguiente &gt;</a>
    </div>
    
    <hr style="border: 0; height: 1.5px; background: #c0d1e1; margin: 40px 0;">
</main>

<!-- Footer -->
<footer class="client-footer">
    <div class="client-footer-inner">
        <img src="/img/ppg-logo.svg" alt="Logo PPG">
        <p>The PPG logo is a registered trademark and Colorful Communities and We protect and beautify the world are trademarks of PPG Industries Ohio, Inc. &copy; 2026 PPG Industries, Inc.All Rights Reserved</p>
    </div>
</footer>

<script src="/nav_bar.js"></script>
</body>
</html>
