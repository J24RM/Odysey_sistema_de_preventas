<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <title>Cliente Cart</title>
</head>
<body>

<nav class="navbar navbar-expand-lg" style="background-color: rgba(0, 120, 169, 0.1);">
    <div class="container-fluid align-items-center">

    <!-- Logo -->
    <a class="navbar-brand" href="/home">
        <img src="/img/ppg-logo.svg" width="60">
    </a>

    <!-- Menu izquierdo -->
    <ul class="navbar-nav me-">
    <li class="nav-item">
        <a class="btn btn-light me-5" id="btnSucursal" data-bs-toggle="modal" data-bs-target="#modalSelector">
            Sucursal
        </a>
    </li>

    <li class="nav-item">
        <a class="btn btn-light" id="btnCuenta" data-bs-toggle="modal" data-bs-target="#modalSelector">
        Cambiar Cuenta
        </a>
    </li>
    </ul>

    <!-- Buscador centrado -->
    <form class="mx-auto search-bar" style="width: 55%;">
        <div class="input-group">

        <input
        type="search"
        class="form-control text-center"
        placeholder="Buscar Producto"
        aria-label="Buscar Producto"
        >

        <button class="btn btn-light" type="submit">
            🔍
        </button>

    </div>
</form>
    <!-- Menu derecho -->
    <ul class="navbar-nav ms-auto align-items-center">

    <li class="nav-item me-5">
        <a class="btn btn-light" href="/profile">Mi Perfil</a>
    </li>

    <li class="nav-item me-5">
        <a href="/cart">
            <img src="https://cdn-icons-png.flaticon.com/512/3144/3144456.png" width="40">
        </a>
    </li>

    <li class="nav-item">
        <a href="/logout">
            <img src="https://cdn-icons-png.flaticon.com/512/6326/6326055.png" width="50">
        </a>
    </li>

    </ul>

    </div>
</nav>

<!-- Card de informacion -->
<div class="modal fade" id="modalSelector" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">

    <div class="modal-content">

        <div class="modal-header">
        <h5 class="modal-title" id="modalTitle"></h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body" id="modalBody">
        </div>

    </div>

    </div>
</div>

<!-- Contenido principal -->
<div class="container mt-5">
    <h1>Mi Carrito</h1>
    <p>Aquí va el contenido del carrito</p>
</div>

<script src="/nav_bar.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
