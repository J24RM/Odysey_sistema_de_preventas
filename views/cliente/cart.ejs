<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Carrito PPG</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    * { font-family: 'Public Sans', sans-serif; }
    .nav-bg { background-color: rgba(0, 120, 169, 0.1); }
    .nav-border { border-color: rgba(0, 120, 169, 0.2); }
  </style>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'ppg-blue': '#0078A9',
            'ppg-cyan': '#1FB5DF',
            'ppg-dark': '#002736',
          }
        }
      }
    }

  </script>
</head>
<body class="bg-gray-100 min-h-screen">

<%- include('../includes/_navbar') %>

<div class="max-w-7xl mx-auto px-6 py-10 flex gap-6 items-start">

  <!-- Columna izquierda -->
  <div class="flex-1 rounded-2xl p-8 shadow-sm p-7 bg-white">

    <div class="flex items-center justify-between mb-6">
      <h1 class="text-4xl font-black text-gray-900">Carrito</h1>
    </div>

    <hr class="border-gray-300 mb-0" />

            <!-- Error -->
      <div id="error-container"
        class="hidden fixed top-4 left-1/2 -translate-x-1/2 z-50
          bg-red-100 border border-red-400 text-red-700
          px-6 py-3 rounded-xl shadow-md text-sm font-medium">
        </div> 

    <% if (!productosCarrito || productosCarrito.length === 0) { %>
      <div class="py-16 text-center text-gray-500 font-medium">
        Tu carrito está vacío.
      </div>
    <% } else { %>

      <div id="eliminados" class="flex flex-col gap-2 mb-4"></div> 

<div id="cart-items">
  <% productosCarrito.forEach(function(item, index) { %>
    <% const producto = detalleProductos[index] && detalleProductos[index][0] %>
    <% if (producto) { %>

    <div id="row-<%= item.id_producto%>"
          class="product-row flex items-center gap-5 py-6 border-b border-gray-300"
          data-precio="<%= producto.precio_unitario %>"
          data-id="<%= item.id_producto %>">

      <!-- Imagen -->
      <div class="w-28 h-28 flex-shrink-0 bg-white rounded-xl flex items-center justify-center overflow-hidden shadow-sm">
        <img src="/uploads/<%= producto.url_imagen || '/img/botePintura.png' %>"
              alt="<%= producto.nombre %>"
              class="object-contain w-24 h-24" />
      </div>

      <!-- Info -->
      <div class="flex-1">
        <a href="/product/<%= item.id_producto %>"
            id="nombre-<%= item.id_producto %>"
            class="text-base font-semibold text-gray-900 hover:underline leading-snug">
          <%= producto.nombre %>
        </a>
        
        <div class="flex items-center gap-4 mt-4">
          <div class="flex items-center gap-2 border-2 rounded-full px-3 py-1" style="border-color: #00000066;">
            <button onclick="cambiarCantidad(<%= item.id_producto %>, -1)"
              class="text-gray-700 font-bold text-lg w-5 h-5 flex items-center justify-center hover:opacity-70 transition">−</button>

            <input
              id="qty-<%= item.id_producto %>"
              type="text"
              value="<%= item.cantidad %>"
              inputmode="numeric"
              class="qty text-sm font-semibold text-gray-800 w-10 text-center outline-none"
              oninput="this.value = this.value.replace(/[^0-9]/g, '')"
              onblur="inputCantidad(<%= item.id_producto %>)"
            />

            <button onclick="cambiarCantidad(<%= item.id_producto %>, 1)"
              class="text-gray-700 font-bold text-lg w-5 h-5 flex items-center justify-center hover:opacity-70 transition">+</button>

          </div>
          <button onclick="eliminarProducto(<%= item.id_producto %>)"                                                                                                                           
            class="text-sm font-medium hover:underline" style="color: #000000;">Eliminar</button>
        </div>
      </div>


      <!-- Precio -->
      <div class="text-right flex-shrink-0">
        <p id="price-<%= item.id_producto %>" class="text-xl font-bold text-gray-900">$ <%= (producto.precio_unitario * item.cantidad).toLocaleString('es-MX') %></p>
        <p class="text-xs text-gray-500 mt-1">($ <%= Number(producto.precio_unitario).toLocaleString('es-MX') %> / unidad)</p>
      </div>

    </div>

    <% } %>
  <% }) %>
</div>

    <% } %>
  </div>

  <!-- Columna derecha -->
  <div class="w-72 flex-shrink-0 flex flex-col gap-4">
    <div class="bg-white rounded-2xl shadow-sm p-7">
      <p class="text-xl font-bold text-gray-600 leading-tight">Subtotal:</p>
      <p class="text-xl font-black text-gray-600 mt-1" id="subtotal-display">$ 0</p>
      <p class="text-2xl font-bold text-gray-900 leading-tight">Total(IVA incluido):</p>
      <p class="text-3xl font-black text-gray-900 mt-1" id="total-display">$ 0</p>
      <p class="text-sm text-gray-500 mt-4 font-medium" id="qty-display">Cantidad de productos: 0</p>
      
    </div>

    <form action="/orden/registrar" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit"
        class="w-full text-white font-bold text-base py-4 rounded-2xl hover:opacity-90 active:scale-95 transition-all duration-150 shadow-md"
        style="background-color: #002736;">
        Realizar orden
      </button>
    </form>

    <p class="text-xs text-gray-500 text-center leading-snug px-2">
      <em>Revisa tu orden, solo tendrás 15 minutos para cancelarla una vez la realices</em>
    </p>
  </div>
  
</div>

<meta name="csrf-token" content="<%= csrfToken %>">
<script src="/JavaScript/carrito.js"></script>

<script>
  // Inicializar la sucursal activa desde la sesión del servidor
  window._sucursalActivaId = <%- locals.sucursal_activa ? locals.sucursal_activa.id_sucursal : 'null' %>;

  document.querySelector('form[action="/orden/registrar"]').addEventListener('submit', function(e) {
    if (!window._sucursalActivaId) {
      e.preventDefault();
      e.stopImmediatePropagation();
      window.abrirModalPerfil({ forzado: true });
    }
  }, true); 
</script>
</body>
</html>

