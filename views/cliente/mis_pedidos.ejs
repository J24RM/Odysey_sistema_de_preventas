<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/svg+xml" href="/img/PPG_Logo2.svg">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/style_cliente_pedidos.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <title>Historial de pedidos</title>
</head>
<body class="bg-gray-50 text-gray-800 flex flex-col min-h-screen">

<%
// pedidos viene del controlador
%>

<script>
window.perfilUsuario = {
    nombre:   "<%= usuarioData && usuarioData.nombre   ? usuarioData.nombre   : (usuarioData && usuarioData.email ? usuarioData.email : 'Usuario') %>",
    email:    "<%= usuarioData && usuarioData.email    ? usuarioData.email    : '' %>",
    telefono: "<%= usuarioData && usuarioData.telefono ? usuarioData.telefono : 'N/A' %>"
};
</script>
<%- include('../includes/_navbar') %>



<!-- Modal Detalle de Orden -->
<div id="modalDetalleOrden" class="tw-modal hidden fixed inset-0 bg-black/50 z-50 items-center justify-center p-4">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-4xl max-h-[90vh] flex flex-col relative detalle-orden-modal text-gray-800">
        <div class="flex items-center justify-center pt-4 pb-2 border-b border-gray-100">
            <h4 class="text-xl font-bold mx-auto">Detalle de orden</h4>
            <button type="button" class="btn-close-modal absolute right-4 top-4 text-gray-500 hover:text-gray-700 text-3xl leading-none">&times;</button>
        </div>
        <div class="p-6 overflow-y-auto">
            
            <!-- Resumen de la orden (fondo celeste) -->
            <div class="resumen-orden-box mb-6 bg-blue-50/50 p-4 rounded-lg border border-blue-100">
                <div class="flex flex-col md:flex-row gap-4">
                    <div class="md:w-1/3">
                        <p class="mb-1 font-bold">Folio: <span id="modal-folio" class="font-normal text-gray-700"></span></p>
                        <p class="mb-0 font-bold">Fecha: <span id="modal-fecha" class="font-normal text-gray-700"></span></p>
                    </div>
                    <div class="md:w-5/12">
                        <p class="mb-1 font-bold">Sucursal: <span id="modal-sucursal" class="font-normal text-gray-700"></span></p>
                        <p class="mb-0 font-bold">Total de productos: <span id="modal-total-productos" class="font-normal text-gray-700"></span></p>
                    </div>
                    <div class="md:w-2/4 md:text-right">
                        <p class="mb-1 font-bold flex items-center md:justify-end gap-2">
                            Estado de la orden: <span id="modal-estado" class="status-pill inline-block px-2 py-1 text-[11px] rounded-full"></span>
                        </p>
                        <p class="mb-0 font-bold flex items-center md:justify-end gap-2">
                            Peso Total:  <span id="modal-peso" class="font-normal text-gray-500"></span>
                        </p>
                        <p class="mb-0 font-bold flex items-center md:justify-end gap-2">
                            Subtotal: <span id="modal-subtotal" class="font-normal text-gray-500"></span>
                        </p>
                        <p class="mb-0 font-bold flex items-center md:justify-end gap-2 text-lg">
                            Total(IVA incluido): <span id="modal-total" class="font-normal text-gray-900"></span>
                        </p>
                    </div>
                </div>
                <!-- Boton de Cancelar -->
                <div id="btn-cancelar" class="w-full flex justify-end mt-4"> </div>
            </div>

            <!-- Titulo y Exportar -->
            <div class="flex justify-between items-center mb-4">
                <h5 class="font-bold text-lg mb-0 text-gray-800">Desglose de orden:</h5>
                <div class="flex gap-2">
                    <a id="btn-descargar-pdf"
                       href="#"
                       target="_blank"
                       class="inline-flex items-center gap-1 shadow-sm border border-blue-200 rounded px-3 py-1 bg-blue-50 hover:bg-blue-100 text-sm font-semibold text-blue-700 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17v3a1 1 0 001 1h16a1 1 0 001-1v-3" />
                        </svg>
                        Descargar PDF
                    </a>
                </div>
            </div>

            <!-- Lista de productos (se llena dinámicamente) -->
            <div id="modal-productos" class="productos-lista space-y-4">
            </div>

        </div>
    </div>
</div>

<!-- Modal Confirmación de Cancelación (Paso 6 del CU-19) -->
<div id="modalConfirmarCancelacion" class="hidden fixed inset-0 bg-black/50 z-[60] flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-xl p-8 max-w-sm w-full text-center mx-4">
        <h2 class="text-xl font-bold text-gray-900 mb-2">¿Cancelar orden?</h2>
        <p class="text-gray-600 text-sm mb-6">Esta acción no se puede deshacer. ¿Estás seguro de que deseas cancelar esta orden?</p>
        <div class="flex gap-3 justify-center">
            <button id="btnNoCancelar"
                class="px-5 py-2 border border-gray-300 rounded-lg font-semibold text-gray-700 hover:bg-gray-50 transition-colors">
                No, regresar
            </button>
            <button id="btnConfirmarCancelacion"
                class="px-5 py-2 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg shadow transition-colors">
                Sí, cancelar
            </button>
        </div>
    </div>
</div>

     <!-- Error -->
      <div id="error-container"
        class="hidden fixed top-4 left-1/2 -translate-x-1/2 z-50
          bg-red-100 border border-red-400 text-red-700
          px-6 py-3 rounded-xl shadow-md text-sm font-medium">
        </div> 

    <!-- Mensaje de confirmacion -->
    <div id="modal-success" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center">
        <div class="bg-white rounded-2xl shadow-xl p-8 max-w-sm w-full text-center mx-4">
            <h2 id="modal-order-msg" class="text-xl font-bold text-gray-900 mb-2"></h2>
            <p id="modal-success-msg" class="text-gray-600 text-sm"></p>
            <p class="text-gray-400 text-xs mt-4">Haz clic en cualquier lugar para cerrar</p>
        </div>
    </div>

<!-- Contenido principal -->
<div class="pedidos-container flex-1">
    <h1 class="pedidos-titulo">Mis Ordenes</h1>

    <!-- Barra de herramientas -->
    <div class="pedidos-toolbar">
        <div class="pedidos-search">
            <input type="text" placeholder="Buscar historial de pedido">
            <button type="button" class="btn-search" aria-label="Buscar pedido">
                <svg width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                  <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                </svg>
            </button>
        </div>


        <div class="pedidos-actions">
            <button class="btn-exportar" type="button">Exportar todo el historial</button>

            <div class="dropdown-filter">
                <select class="select-filter">
                    <option>30 días</option>
                    <option>7 días</option>
                    <option>90 días</option>
                    <option>Último año</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Resumen estadísticas -->
    <%
        const hoy = new Date().toDateString();
        const ordenesDe_hoy = pedidos.filter(p => p.fecha_realizada && new Date(p.fecha_realizada).toDateString() === hoy).length;
        const ordenesConfirmadas = pedidos.filter(p => p.estado === 'confirmada').length;
    %>
    <div class="pedidos-stats">
        <div class="stat-item">
            <span class="stat-label">Hoy</span>
            <span class="stat-value"><%= ordenesDe_hoy %></span>
        </div>
        <div class="stat-item">
            <span class="stat-label">Órdenes Totales</span>
            <span class="stat-value"><%= pedidos.length %></span>
        </div>
        <div class="stat-item">
            <span class="stat-label">Órdenes confirmadas</span>
            <span class="stat-value"><%= ordenesConfirmadas %></span>
        </div>
    </div>

    <!-- Tabla de pedidos -->
    <div class="pedidos-table-card">
        <div class="pedidos-table-head">
            <span>Orden</span>
            <span>Fecha</span>
            <span>Sucursal</span>
            <span>Total</span>
            <span class="text-center">Estatus de pedido</span>
        </div>

        <div class="pedidos-table-body">
            <div id="no-orders-msg" class="py-16 text-center text-gray-500 font-medium<%= pedidos.length === 0 ? '' : ' hidden' %>">
                No tienes órdenes registradas aún.
            </div>
            <% pedidos.forEach((pedido) => { %>
                <% const fecha = pedido.fecha_realizada ? new Date(pedido.fecha_realizada).toLocaleDateString('es-MX', { day: '2-digit', month: 'long', year: 'numeric' }) : 'Sin fecha'; %>
                <% const estado = pedido.estado.charAt(0).toUpperCase() + pedido.estado.slice(1); %>
                <% const total = pedido.subtotal * 1.16; %>
                <div class="pedidos-row" data-id="<%= pedido.id_orden %>" data-fecha="<%= pedido.fecha_realizada || '' %>" data-sucursal="<%= pedido.sucursal ? pedido.sucursal.nombre_sucursal : 'Sin sucursal' %>" style="cursor:pointer;">
                    <span><%= pedido.folio%></span>
                    <span><%= fecha %></span>
                    <span><%= pedido.sucursal ? pedido.sucursal.nombre_sucursal : 'Sin sucursal' %></span>
                    <span>$<%= total ? total.toLocaleString('es-MX', { minimumFractionDigits: 2 }) : '0.00' %></span>
                    <span class="status-cell">
                        <span class="status-pill <%= estado === 'Pendiente' ? 'status-pending' : estado === 'Cancelada' ? 'status-cancelled' : 'status-confirmed' %>">
                            <%= estado %>
                        </span>
                    </span>
                </div>
            <% }); %>
        </div>
    </div>

    <!-- Paginación -->
    <div id="paginacion" class="pedidos-paginacion">
        <button id="btn-prev">&#8592; Anterior</button>
        <span id="info-pagina">Página 1 de 1</span>
        <button id="btn-next">Siguiente &#8594;</button>
    </div>
</div>

<%- include('../includes/_footer') %>


<meta name="csrf-token" content="<%= csrfToken %>">

<script>
// Paso 6.1: No cancelar — cerrar modal de confirmación y regresar al detalle
document.getElementById('btnNoCancelar').addEventListener('click', () => {
    document.getElementById('modalConfirmarCancelacion').classList.add('hidden');
});

// Paso 7: Confirmar cancelación — enviar el form
document.getElementById('btnConfirmarCancelacion').addEventListener('click', () => {
    const form = document.getElementById('formCancelarOrden');
    if (form) form.submit();
});

// ─── Paginación ──────────────────────────────────────────────────────────────

const PAGE_SIZE = 20;
let currentPage  = 1;
let visibleRows  = [];

function calcularVisibles() {
    const query = document.querySelector('.pedidos-search input').value.trim().toLowerCase();
    const valor  = document.querySelector('.select-filter').value;
    const ahora  = new Date();
    let diasAtras = null;
    if (valor === '7 días')        diasAtras = 7;
    else if (valor === '30 días')  diasAtras = 30;
    else if (valor === '90 días')  diasAtras = 90;
    else if (valor === 'Último año') diasAtras = 365;

    return Array.from(document.querySelectorAll('.pedidos-row')).filter(row => {
        if (query && !row.textContent.toLowerCase().includes(query)) return false;
        if (diasAtras) {
            const fechaISO = row.dataset.fecha;
            if (fechaISO) {
                const limite = new Date(ahora);
                limite.setDate(ahora.getDate() - diasAtras);
                if (new Date(fechaISO) < limite) return false;
            }
        }
        return true;
    });
}

function renderPagina(pagina) {
    currentPage = pagina;
    const todosRows = document.querySelectorAll('.pedidos-row');
    todosRows.forEach(r => r.style.display = 'none');

    const inicio = (pagina - 1) * PAGE_SIZE;
    visibleRows.slice(inicio, inicio + PAGE_SIZE).forEach(r => r.style.display = '');

    const totalPaginas = Math.max(1, Math.ceil(visibleRows.length / PAGE_SIZE));
    document.getElementById('info-pagina').textContent = `Página ${pagina} de ${totalPaginas}`;
    document.getElementById('btn-prev').disabled = pagina === 1;
    document.getElementById('btn-next').disabled = pagina >= totalPaginas;

    const noMsg = document.getElementById('no-orders-msg');
    noMsg.style.display = visibleRows.length === 0 ? '' : 'none';

    // Ocultar controles si todo cabe en una página
    document.getElementById('paginacion').style.display =
        visibleRows.length > PAGE_SIZE ? 'flex' : 'none';
}

function aplicarFiltros() {
    visibleRows = calcularVisibles();
    renderPagina(1);
}

document.getElementById('btn-prev').addEventListener('click', () => renderPagina(currentPage - 1));
document.getElementById('btn-next').addEventListener('click', () => renderPagina(currentPage + 1));

// Búsqueda en historial
document.querySelector('.pedidos-search input').addEventListener('input', aplicarFiltros);

// Filtro por periodo de tiempo
document.querySelector('.select-filter').addEventListener('change', aplicarFiltros);

// Modal logic
const modal = document.getElementById('modalDetalleOrden');
const closeBtn = modal.querySelector('.btn-close-modal');

function cerrarModalDetalle() {
    modal.classList.add('hidden');
    modal.style.display = 'none';
    if (window._contadorCancelacion) {
        clearInterval(window._contadorCancelacion);
        window._contadorCancelacion = null;
    }
}

closeBtn.addEventListener('click', cerrarModalDetalle);
modal.addEventListener('click', (e) => {
    if (e.target === modal) cerrarModalDetalle();
});

document.querySelector('.pedidos-table-body').addEventListener('click', async (e) => {
    const row = e.target.closest('.pedidos-row');
    if (!row) return;
    {
        const idOrden = row.dataset.id;
        try {
            showLoader();
            const res = await fetch(`/orden/detalle/${idOrden}`);
            const { orden, detalles } = await res.json();
            console.log(detalles);

            const res2 = await fetch(`/orden/detalle/${idOrden}`);
            const { producto } = await res2.json();
            console.log(detalles);

            // Fill summary
            document.getElementById('modal-folio').textContent = 'A' + String(orden.id_orden).padStart(4, '0');
            const fecha = orden.fecha_realizada ? new Date(orden.fecha_realizada).toLocaleDateString('es-MX') : 'N/A';
            document.getElementById('modal-fecha').textContent = fecha;
            document.getElementById('modal-sucursal').textContent = row.dataset.sucursal || 'Sin sucursal';
            
            const totalProductos = detalles.reduce((sum, d) => sum + d.cantidad, 0);
            document.getElementById('modal-total-productos').textContent = totalProductos;

            const estadoEl = document.getElementById('modal-estado');
            const estado = orden.estado.charAt(0).toUpperCase() + orden.estado.slice(1);
            estadoEl.textContent = estado;
            estadoEl.className = 'status-pill inline-block px-2 py-1 text-[11px] rounded-full ' +
                (estado === 'Cancelada' ? 'status-cancelled' : 'status-confirmed');

            document.getElementById('modal-subtotal').textContent = orden.subtotal ? 
                Number(orden.subtotal).toLocaleString('es-MX', { minimumFractionDigits: 2 }) : '0.00';

            // Peso
            document.getElementById('modal-peso').textContent = orden.peso_total + ' Kg';

            const total = orden.subtotal * 1.16;

            document.getElementById('modal-total').textContent = total ? 
                Number(total).toLocaleString('es-MX', { minimumFractionDigits: 2 }) : '0.00';

            const btnContainer = document.getElementById('btn-cancelar');
            btnContainer.innerHTML = '';

            // Boton de Cancelar
            const csrfToken = document.querySelector('meta[name="csrf-token"]').content;

            // Limpiar contador anterior si existía
            if (window._contadorCancelacion) {
                clearInterval(window._contadorCancelacion);
                window._contadorCancelacion = null;
            }

            if(orden.cancelar == true){
                btnContainer.innerHTML = `
                    <div class="flex flex-col items-end gap-1">
                        <form id="formCancelarOrden" action="/orden/cancelar/${orden.id_orden}" method="POST">
                            <input type="hidden" name="_csrf" value="${csrfToken}">
                            <button type="button" id="btnAbrirConfirmacion"
                                class="inline-flex items-center justify-center px-4 py-2 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg shadow transition-colors duration-200">
                                Cancelar Orden
                            </button>
                        </form>
                        <p class="text-xs text-gray-500">Tiempo restante para cancelar: <span id="contadorTiempo" class="font-semibold text-red-500"></span></p>
                    </div>
                `;

                // Paso 6: abrir modal de confirmación en lugar de enviar directo
                document.getElementById('btnAbrirConfirmacion').addEventListener('click', () => {
                    document.getElementById('modalConfirmarCancelacion').classList.remove('hidden');
                });

                // Contador regresivo
                let segundos = orden.segundosRestantes || 0;
                const spanContador = document.getElementById('contadorTiempo');

                function actualizarContador() {
                    const m = String(Math.floor(segundos / 60)).padStart(2, '0');
                    const s = String(segundos % 60).padStart(2, '0');
                    spanContador.textContent = `${m}:${s}`;
                }
                actualizarContador();

                window._contadorCancelacion = setInterval(() => {
                    segundos--;
                    if (segundos <= 0) {
                        clearInterval(window._contadorCancelacion);
                        window._contadorCancelacion = null;
                        spanContador.textContent = '00:00';
                        // Ocultar botón y mostrar mensaje de tiempo expirado
                        document.getElementById('btnAbrirConfirmacion').disabled = true;
                        document.getElementById('btnAbrirConfirmacion').classList.add('opacity-50', 'cursor-not-allowed');
                        document.getElementById('btnAbrirConfirmacion').textContent = 'Tiempo expirado';
                    } else {
                        actualizarContador();
                    }
                }, 1000);
            }

            // Fill products
            const container = document.getElementById('modal-productos');
            container.innerHTML = '';
            detalles.forEach(d => {
                const precio = d.producto.precio_unitario;
                const peso = d.producto.peso * d.cantidad;
                const total = precio * d.cantidad;
                let img = '/img/botePintura.png';
                if (d.producto.url_imagen) {
                    img = d.producto.url_imagen.startsWith('/uploads/') 
                        ? d.producto.url_imagen 
                        : '/uploads/' + d.producto.url_imagen.replace(/^\//, '');
                }
                container.innerHTML += `
                    <div class="producto-item flex flex-col sm:flex-row items-center gap-4 border-b border-gray-100 pb-4">
                        <div class="img-box w-16 h-16 shrink-0 bg-gray-50 border border-gray-200 rounded p-1">
                            <img src="${img}" alt="Producto" class="w-full h-full object-contain" onerror="this.src='https://cdn-icons-png.flaticon.com/512/1170/1170679.png'">
                        </div>
                        <div class="producto-info flex-grow text-center sm:text-left">
                            <h6 class="font-medium text-gray-700 mb-2 text-sm sm:max-w-[90%] pointer-events-auto h-auto">
                                <a href="/product/${d.id_producto}" class="hover:underline">${d.producto.nombre}</a>
                            </h6>
                            <h6 class="font-medium text-gray-700 mb-2 text-sm sm:max-w-[90%] pointer-events-auto h-auto">
                                SKU: ${d.producto.clave}
                            </h6>
                            <div class="flex items-center justify-center sm:justify-start gap-2">
                                <div class="cantidad-box text-sm text-gray-500 font-medium bg-gray-100 px-2 py-1 rounded">
                                    Unidades: ${d.cantidad}
                                </div>
                            </div>
                        </div>
                        <div class="producto-precio text-center sm:text-right shrink-0 mt-2 sm:mt-0">
                            <div class="font-bold text-lg text-gray-800">$ ${total.toLocaleString('es-MX')}</div>
                            <div class="text-gray-500 text-[11px]">($ ${Number(precio).toLocaleString('es-MX')} / unidad)</div>
                            <div class="text-gray-500 text-[11px]">( ${Number(peso)} Kg)</div>
                        </div>
                    </div>
                `;
            });

            // Enlace de descarga PDF
            document.getElementById('btn-descargar-pdf').href = `/orden/pdf/${idOrden}`;

            modal.classList.remove('hidden');
            modal.style.display = 'flex';
        } catch (err) {
            console.error('Error cargando detalle:', err);
        } finally {
            hideLoader();
        }
    }
});

// Error
function mostrarError(mensaje) {
    const contenedor = document.getElementById('error-container');
    contenedor.textContent = mensaje;
    contenedor.classList.remove('hidden');
    setTimeout(() => contenedor.classList.add('hidden'), 4000);
}

document.addEventListener('DOMContentLoaded', () => {
    // Inicializar paginación con el filtro de tiempo por defecto
    aplicarFiltros();

    const params = new URLSearchParams(window.location.search);
    if (params.get('error')) {
        mostrarError(decodeURIComponent(params.get('error')));
        window.history.replaceState({}, '', '/cliente/mis-pedidos');
    }

    if (params.get('success')) {
        const modalSuccess = document.getElementById('modal-success');
        document.getElementById('modal-success-msg').textContent = decodeURIComponent(params.get('success'));
        document.getElementById('modal-order-msg').textContent = decodeURIComponent(params.get('order'));
        modalSuccess.classList.remove('hidden');
        window.history.replaceState({}, '', '/cliente/mis-pedidos');

        modalSuccess.addEventListener('click', () => {
            modalSuccess.classList.add('hidden');
        });
    }
});

document.querySelector('.btn-exportar').addEventListener('click', () => {
    const params = new URLSearchParams(window.location.search);
    window.location.href = `/orden/exportar-historial`;
});

</script>


</body>
</html>
