<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Error <%= codigo %></title>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center">
    <div class="text-center max-w-md mx-auto px-6">

        <div class="text-8xl font-black text-[#0078A9] mb-4"><%= codigo %></div>

        <h1 class="text-2xl font-bold text-gray-800 mb-2"><%= mensaje %></h1>
        <p class="text-gray-500 text-sm mb-8"><%= detalle %></p>

        <a href="javascript:history.back()"
           class="inline-block bg-[#0078A9] text-white font-semibold px-6 py-2 rounded-md hover:bg-[#005f87] transition-colors mr-2">
            Regresar
        </a>
        <a href="/cliente/home"
           class="inline-block border border-gray-300 text-gray-700 font-semibold px-6 py-2 rounded-md hover:bg-gray-100 transition-colors">
            Ir al inicio
        </a>

    </div>
</body>
</html>