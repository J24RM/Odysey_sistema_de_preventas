<!-- Header -->
<header class="sticky top-0 z-50 bg-blue-50 border-b border-blue-100 shadow-sm">
    <div class="flex items-center justify-between px-7 h-[60px]">
        <div class="flex-shrink-0">
            <img src="/img/ppg-logo.svg" alt="Logo PPG" class="h-11">
        </div>
        <!-- Stats que remplazan barra de busqueda -->
        <div class="flex-1 flex items-center justify-center gap-8 mx-8">
            <div class="flex items-center gap-2">
                <span class="text-xs font-semibold text-gray-600">Pedidos confirmados hoy:</span>
                <span class="text-lg font-extrabold text-gray-900">12</span>
            </div>
            <div class="w-px h-6 bg-gray-300"></div>
            <div class="flex items-center gap-2">
                <span class="text-xs font-semibold text-gray-600">Producto más popular:</span>
                <span class="text-lg font-extrabold text-gray-900">SELLADOR-001</span>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <a href="/logout" class="inline-flex items-center justify-center px-3.5 py-2 rounded-full border border-gray-300 bg-white text-blue-600 font-bold text-sm hover:bg-blue-600 hover:text-white transition-all">
                Cerrar sesión
            </a>
            <div class="w-11 h-11 rounded-full overflow-hidden flex-shrink-0">
                <img src="/img/iconoPerfil.png" alt="Usuario" class="w-full h-full object-cover">
            </div>
        </div>
    </div>
</header>
