<!DOCTYPE html>
<html lang="es">

<head>
<meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/img/PPG_Logo2.svg">
<title>Estadísticas Generales</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
    * { font-family: 'Public Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }

</style>
</head>

<body class="bg-gray-50">

<%- include('partials/header.ejs') %>
<%- include('partials/sidebar.ejs') %>

<main class="ml-48 pt-2 px-10 pb-9 flex-1 min-h-[calc(100vh-70px)]">

    <!-- Tabs -->
    <div class="flex gap-1 border-b-2 border-gray-200 mb-6">
        <a href="/admin/stats" class="tab-link px-5 py-2.5 text-sm font-semibold text-gray-500 hover:text-gray-800 transition-colors border-b-2 border-transparent -mb-[2px]" data-tab="/admin/stats">Generales</a>
        <a href="/admin/stats/sucursales" class="tab-link px-5 py-2.5 text-sm font-semibold text-gray-500 hover:text-gray-800 transition-colors border-b-2 border-transparent -mb-[2px]" data-tab="/admin/stats/sucursales">Sucursales</a>
        <a href="/admin/stats/productos" class="tab-link px-5 py-2.5 text-sm font-semibold text-gray-500 hover:text-gray-800 transition-colors border-b-2 border-transparent -mb-[2px]" data-tab="/admin/stats/productos">Productos</a>
    </div>

    <!-- Section title -->
    <p class="text-[13px] font-bold text-gray-400 tracking-wide mb-5 uppercase">Estadísticas Generales del Mes (Resumen)</p>

    <!-- Top 3-column cards -->
    <div class="grid grid-cols-3 gap-5 mb-6">

        <!-- Card 1: Producto más vendido -->
        <div class="bg-white rounded-[14px] p-5 shadow-[0_4px_16px_rgba(0,0,0,0.07)]">
            <p class="text-[11px] font-bold text-gray-400 tracking-wide uppercase mb-4">Producto más vendido semanalmente</p>
            <% if (productoMasVendido) { %>
            <div class="flex items-center gap-4">
                <div class="w-24 h-24 flex-shrink-0 bg-gray-50 rounded-xl overflow-hidden flex items-center justify-center border border-gray-100">
                    <% if (productoMasVendido.img) { %>
                        <img src="/uploads/<%= productoMasVendido.img %>" alt="Producto" class="max-w-full max-h-full object-contain"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                        <span class="text-3xl hidden items-center justify-center">📦</span>
                    <% } else { %>
                        <span class="text-3xl">📦</span>
                    <% } %>
                </div>
                <div>
                    <p class="text-sm font-bold text-gray-800 leading-snug"><%= productoMasVendido.nombre %></p>
                    <% if (productoMasVendido.desc) { %>
                    <p class="text-xs text-gray-400 mt-1"><%= productoMasVendido.desc %></p>
                    <% } %>
                </div>
            </div>
            <% } else { %>
            <div class="flex flex-col items-center justify-center py-8 text-center">
                <span class="text-4xl mb-2">📦</span>
                <p class="text-xs text-gray-400">Sin datos esta semana</p>
            </div>
            <% } %>
        </div>

        <!-- Card 2: Total ventas del mes -->
        <div class="bg-white rounded-[14px] p-5 shadow-[0_4px_16px_rgba(0,0,0,0.07)]">
            <p class="text-[11px] font-bold text-gray-400 tracking-wide uppercase mb-4">Total de ventas en el mes</p>
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-sm font-semibold text-gray-600 mb-1">Ventas Mensuales</p>
                    <p class="text-5xl font-extrabold text-gray-800 leading-none"><%= totalMensual %></p>
                    <p class="text-xs text-gray-400 mt-2">Realizados en total</p>
                </div>
            </div>
        </div>

        <!-- Card 3: Total ventas semanales -->
        <div class="bg-white rounded-[14px] p-5 shadow-[0_4px_16px_rgba(0,0,0,0.07)]">
            <p class="text-[11px] font-bold text-gray-400 tracking-wide uppercase mb-4">Total de ventas semanales</p>
            <p class="text-sm font-semibold text-gray-600 mb-3">Ventas Semanales</p>
            <div class="flex gap-6">
                <div>
                    <p class="text-4xl font-extrabold text-gray-800 leading-none"><%= totalSemanal %></p>
                    <p class="text-xs text-gray-400 mt-1">Pedidos</p>
                </div>
                <div class="w-px bg-gray-200 self-stretch mx-1"></div>
                <div>
                    <p class="text-4xl font-extrabold text-gray-800 leading-none"><%= productosSemanal %></p>
                    <p class="text-xs text-gray-400 mt-1">Productos</p>
                </div>
            </div>
        </div>

    </div>

    <!-- Line chart card: Total de ventas en el mes -->
    <div class="bg-white rounded-[14px] p-6 shadow-[0_4px_16px_rgba(0,0,0,0.07)] mb-6">
        <p class="text-[13px] font-bold text-gray-400 tracking-wide mb-6 uppercase">COMPARACIÓN: TOTAL DE VENTAS EN EL MES</p>

        <canvas id="chart"></canvas>
    </div>

    <!-- Weekly branches table -->
    <div class="bg-white rounded-[14px] shadow-[0_4px_16px_rgba(0,0,0,0.07)] overflow-hidden">
        <div class="px-6 pt-5 pb-4 border-b border-gray-100 flex items-center justify-between gap-4 flex-wrap">
            <p class="text-[13px] font-bold text-gray-400 tracking-wide uppercase">Top 10 sucursales con más pedidos</p>
            <div class="flex gap-1">
                <a href="/admin/stats?semana=0"
                   class="px-3 py-1.5 text-xs font-semibold rounded transition-colors <%= semanaFiltro === 0 ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
                   Semana actual
                </a>
                <a href="/admin/stats?semana=1"
                   class="px-3 py-1.5 text-xs font-semibold rounded transition-colors <%= semanaFiltro === 1 ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
                   Semana pasada
                </a>
                <a href="/admin/stats?semana=2"
                   class="px-3 py-1.5 text-xs font-semibold rounded transition-colors <%= semanaFiltro === 2 ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
                   Hace 2 semanas
                </a>
            </div>
        </div>
        <% if (!topSucursalesChart || topSucursalesChart.length === 0) { %>
        <div class="flex flex-col items-center justify-center py-14 text-center">
            <span class="text-4xl mb-3">🏪</span>
            <p class="text-gray-400 text-sm">Sin pedidos confirmados en este período.</p>
        </div>
        <% } else { %>
        <table class="w-full">
            <thead>
                <tr class="text-left">
                    <th class="px-6 py-3 text-[11px] font-bold text-gray-400 uppercase tracking-wider">Sucursal</th>
                    <th class="px-6 py-3 text-[11px] font-bold text-gray-400 uppercase tracking-wider">Gerente</th>
                    <th class="px-6 py-3 text-[11px] font-bold text-gray-400 uppercase tracking-wider">Pedidos</th>
                    <th class="px-6 py-3 text-[11px] font-bold text-gray-400 uppercase tracking-wider">Ingresos</th>
                    <th class="px-6 py-3 text-[11px] font-bold text-gray-400 uppercase tracking-wider">% de ingresos</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                <% topSucursalesChart.forEach(s => { %>
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4 text-sm font-semibold text-gray-800"><%= s.nombre_sucursal %></td>
                    <td class="px-6 py-4 text-sm text-gray-500"><%= s.nombre_cuenta %></td>
                    <td class="px-6 py-4">
                        <span class="inline-flex items-center justify-center min-w-[2rem] px-2.5 py-1 rounded-full text-sm font-bold bg-blue-100 text-blue-700">
                            <%= s.total_ordenes %>
                        </span>
                    </td>
                    <td class="px-6 py-4">
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-bold bg-emerald-50 text-emerald-700">
                            <%
                                const v = s.total_ventas;
                                let fmt;
                                if (v >= 1000000) fmt = '$' + (v/1000000).toFixed(1) + 'M';
                                else if (v >= 1000) fmt = '$' + Math.round(v/1000) + 'K';
                                else fmt = '$' + Math.round(v);
                            %>
                            <%= fmt %>
                        </span>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-2">
                            <div class="flex-1 bg-gray-100 rounded-full h-1.5 min-w-[60px]">
                                <div class="bg-blue-500 h-1.5 rounded-full" style="width:<%= s.porcentaje %>%"></div>
                            </div>
                            <span class="text-xs font-bold text-gray-700 w-9 text-right"><%= s.porcentaje %>%</span>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>

</main>

<%- include('partials/footer.ejs') %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const currentPath = window.location.pathname;
    document.querySelectorAll('.tab-link').forEach(tab => {
        if (tab.dataset.tab === currentPath) {
            tab.classList.add('border-blue-600', 'text-blue-600');
            tab.classList.remove('text-gray-500');
        }
    });

    const vd = <%- JSON.stringify(typeof ventasDiarias !== 'undefined' ? ventasDiarias : { actual: [], anterior: [], diasEnMes: 30 }) %>;
    const diasMes = vd.diasEnMes || 30;
    const dataActual = vd.actual || [];
    const dataAnterior = vd.anterior || [];

    // Create labels based on number of days (e.g., 1, 2, 3...)
    const labels = Array.from({length: diasMes}, (_, i) => (i + 1).toString());

    const ctx = document.getElementById('chart');
    if (ctx) {
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Periodo Actual',
                        data: dataActual,
                        tension: 0.4
                    },
                    {
                        label: 'Periodo Anterior',
                        data: dataAnterior,
                        tension: 0.4
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });
    }
</script>

</body>
</html>
