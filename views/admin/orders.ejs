<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Historial de órdenes</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Public Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-50">
    <%- include('partials/header.ejs') %>

    <div class="flex min-h-screen flex-col">
        <%- include('partials/sidebar.ejs') %>

        <!-- Main Content -->
        <main class="ml-48 pt-2 px-10 pb-9 flex-1">
            <section class="space-y-6">
                <!-- Header -->
                <div class="flex items-center justify-between">
                    <h1 class="text-3xl font-extrabold text-gray-900">Historial de órdenes</h1>
                </div>

                <!-- Search -->
                <div class="flex-1 relative">
                    <input id="buscador" type="text" placeholder="Buscar por folio, cliente o estado"
                        class="w-full px-5 py-2.5 border-2 border-gray-300 rounded-full text-sm font-medium focus:border-blue-600 focus:outline-none transition-colors" />
                </div>

                <p class="text-sm font-semibold text-gray-600 uppercase tracking-wide">
                    Mostrando <%= ordenes.length %> de <%= total %> órdenes &mdash; Página <%= paginaActual %> de <%= Math.max(totalPaginas, 1) %>
                </p>

                <!-- Orders Table -->
                <div class="bg-white rounded-2xl shadow-md overflow-hidden">
                    <!-- Table Header -->
                    <div class="grid grid-cols-5 gap-4 px-6 py-4 border-b-2 border-gray-200 bg-gray-50">
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Orden</span>
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Fecha</span>
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Cliente</span>
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Total</span>
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Estatus</span>
                    </div>

                    <!-- Table Body -->
                    <div id="tabla-ordenes" class="divide-y divide-gray-200">
                        <% if (ordenes.length === 0) { %>
                            <div class="py-16 text-center text-gray-500 font-medium">
                                No hay órdenes registradas.
                            </div>
                        <% } %>
                        <% ordenes.forEach((orden) => { %>
                            <%
                                const folio = orden.folio || ('A' + String(orden.id_orden).padStart(4, '0'));
                                const fecha = orden.fecha_realizada
                                    ? new Date(orden.fecha_realizada).toLocaleDateString('es-MX', { day: '2-digit', month: 'long', year: 'numeric' })
                                    : 'Sin fecha';
                                const cliente = orden.usuario?.email || 'N/A';
                                const subtotal = parseFloat(orden.subtotal) || 0;
                                const totalConIva = (subtotal * 1.16).toLocaleString('es-MX', { minimumFractionDigits: 2 });
                                const statusMap = {
                                    'confirmada': { label: 'Confirmada', cls: 'bg-green-100 text-green-800' },
                                    'cancelada':  { label: 'Cancelada',  cls: 'bg-red-100 text-red-800' }
                                };
                                const status = statusMap[orden.estado] || { label: orden.estado, cls: 'bg-gray-100 text-gray-800' };
                            %>
                            <div class="orden-row grid grid-cols-5 gap-4 px-6 py-4 items-center hover:bg-blue-50 transition-colors cursor-pointer"
                                    data-id="<%= orden.id_orden %>"
                                    data-texto="<%= folio.toLowerCase() %> <%= cliente.toLowerCase() %> <%= status.label.toLowerCase() %>">
                                <span class="font-semibold text-gray-900"><%= folio %></span>
                                <span class="text-gray-600 text-sm"><%= fecha %></span>
                                <span class="text-gray-600 text-sm truncate" title="<%= cliente %>"><%= cliente %></span>
                                <span class="font-semibold text-gray-900">$<%= totalConIva %></span>
                                <div>
                                    <span class="inline-block px-3 py-1 rounded-full text-xs font-bold <%= status.cls %>">
                                        <%= status.label %>
                                    </span>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>

                <!-- Pagination -->
                <% if (totalPaginas > 1) { %>
                <div class="flex items-center justify-center gap-3 pt-2">
                    <% if (paginaActual > 1) { %>
                        <a href="/admin/orders?page=<%= paginaActual - 1 %>"
                            class="px-5 py-2.5 bg-white border-2 border-gray-300 rounded-lg font-semibold text-sm text-gray-700 hover:bg-gray-100 transition-all">
                            ← Anterior
                        </a>
                    <% } else { %>
                        <span class="px-5 py-2.5 bg-gray-100 border-2 border-gray-200 rounded-lg font-semibold text-sm text-gray-400 cursor-not-allowed">
                            ← Anterior
                        </span>
                    <% } %>

                    <span class="px-4 py-2 text-sm font-semibold text-gray-700">
                        Página <%= paginaActual %> de <%= totalPaginas %>
                    </span>

                    <% if (paginaActual < totalPaginas) { %>
                        <a href="/admin/orders?page=<%= paginaActual + 1 %>"
                            class="px-5 py-2.5 bg-white border-2 border-gray-300 rounded-lg font-semibold text-sm text-gray-700 hover:bg-gray-100 transition-all">
                            Siguiente →
                        </a>
                    <% } else { %>
                        <span class="px-5 py-2.5 bg-gray-100 border-2 border-gray-200 rounded-lg font-semibold text-sm text-gray-400 cursor-not-allowed">
                            Siguiente →
                        </span>
                    <% } %>
                </div>
                <% } %>

            </section>
        </main>
    </div>

    <!-- Modal Detalle de Orden -->
    <div id="modalDetalle" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-4xl max-h-[90vh] flex flex-col relative">
            <div class="flex items-center justify-center pt-5 pb-3 border-b border-gray-100 flex-shrink-0">
                <h4 class="text-xl font-bold mx-auto">Detalle de orden</h4>
                <button id="btnCerrarModal" class="absolute right-5 top-4 text-gray-400 hover:text-gray-700 text-3xl leading-none">&times;</button>
            </div>
            <div class="p-6 overflow-y-auto">
                <!-- Resumen -->
                <div class="bg-blue-50/50 border border-blue-100 rounded-xl p-5 mb-6">
                    <div class="grid grid-cols-3 gap-6">
                        <div class="space-y-3">
                            <div>
                                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Folio</p>
                                <p id="m-folio" class="font-bold text-gray-900 mt-0.5"></p>
                            </div>
                            <div>
                                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Fecha</p>
                                <p id="m-fecha" class="font-bold text-gray-900 mt-0.5"></p>
                            </div>
                        </div>
                        <div class="space-y-3">
                            <div>
                                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Sucursal</p>
                                <p id="m-sucursal" class="font-bold text-gray-900 mt-0.5"></p>
                            </div>
                            <div>
                                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">RFC de cuenta</p>
                                <p id="m-rfc" class="font-bold text-gray-900 mt-0.5"></p>
                            </div>
                            <div>
                                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Total de productos</p>
                                <p id="m-total-productos" class="font-bold text-gray-900 mt-0.5"></p>
                            </div>
                        </div>
                        <div class="space-y-3">
                            <div>
                                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Estado de orden</p>
                                <span id="m-estado" class="inline-block mt-1 px-3 py-1 rounded-full text-xs font-bold"></span>
                            </div>
                            <div>
                                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Subtotal</p>
                                <p id="m-subtotal" class="font-bold text-gray-900 mt-0.5"></p>
                            </div>
                            <div>
                                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Total (IVA incluido)</p>
                                <p id="m-total" class="font-bold text-gray-900 text-lg mt-0.5"></p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Lista de productos -->
                <h2 class="text-lg font-extrabold text-gray-900 mb-4">Productos</h2>
                <div id="m-productos" class="space-y-3"></div>
            </div>
        </div>
    </div>

    <%- include('partials/footer.ejs') %>

    <script>
        // Búsqueda en tabla
        document.getElementById('buscador').addEventListener('input', function () {
            const q = this.value.trim().toLowerCase();
            document.querySelectorAll('.orden-row').forEach(row => {
                row.style.display = row.dataset.texto.includes(q) ? '' : 'none';
            });
        });

        // Cerrar modal
        const modal = document.getElementById('modalDetalle');
        document.getElementById('btnCerrarModal').addEventListener('click', () => modal.classList.add('hidden'));
        modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.add('hidden'); });

        // Abrir modal al hacer clic en una fila
        document.querySelectorAll('.orden-row').forEach(row => {
            row.addEventListener('click', async () => {
                const id = row.dataset.id;
                try {
                    const response = await fetch(`/admin/orders/detalle/${id}`);
                    const { orden, detalles, sucursalNombre, rfc } = await response.json();

                    const folio = orden.folio || ('A' + String(orden.id_orden).padStart(4, '0'));
                    document.getElementById('m-folio').textContent = folio;
                    document.getElementById('m-fecha').textContent = orden.fecha_realizada
                        ? new Date(orden.fecha_realizada).toLocaleDateString('es-MX', { day: '2-digit', month: 'long', year: 'numeric' })
                        : 'N/A';
                    document.getElementById('m-sucursal').textContent = sucursalNombre;
                    document.getElementById('m-rfc').textContent = rfc || 'N/A';

                    const totalProds = detalles.reduce((s, d) => s + d.cantidad, 0);
                    document.getElementById('m-total-productos').textContent = totalProds;

                    const estadoEl = document.getElementById('m-estado');
                    const estadoLabel = orden.estado.charAt(0).toUpperCase() + orden.estado.slice(1);
                    estadoEl.textContent = estadoLabel;
                    estadoEl.className = 'inline-block mt-1 px-3 py-1 rounded-full text-xs font-bold ' +
                        (orden.estado === 'cancelada' ? 'bg-red-100 text-red-800' : 'bg-green-100 text-green-800');

                    const subtotal = parseFloat(orden.subtotal) || 0;
                    document.getElementById('m-subtotal').textContent =
                        '$' + subtotal.toLocaleString('es-MX', { minimumFractionDigits: 2 });
                    document.getElementById('m-total').textContent =
                        '$' + (subtotal * 1.16).toLocaleString('es-MX', { minimumFractionDigits: 2 });

                    const container = document.getElementById('m-productos');
                    container.innerHTML = '';
                    if (detalles.length === 0) {
                        container.innerHTML = '<p class="text-gray-500 text-sm text-center py-6">Sin productos registrados.</p>';
                    }
                    detalles.forEach(d => {
                        const precio = parseFloat(d.producto?.precio_unitario) || 0;
                        const totalProd = precio * d.cantidad;
                        const img = d.producto?.url_imagen || '/img/botePintura.png';
                        container.innerHTML += `
                            <div class="flex gap-5 p-4 border border-gray-100 rounded-xl hover:bg-gray-50 transition-colors">
                                <div class="w-20 h-20 flex-shrink-0 rounded-lg bg-gray-100 flex items-center justify-center">
                                    <img src="${img}" alt="Producto" class="max-h-16 max-w-full object-contain"
                                         onerror="this.src='/img/botePintura.png'">
                                </div>
                                <div class="flex-1 flex items-center justify-between gap-4">
                                    <div>
                                        <p class="font-bold text-gray-900 text-sm">${d.producto?.nombre || 'Producto'}</p>
                                        <p class="text-xs text-gray-400 mt-0.5">SKU: ${d.producto?.clave || 'N/A'}</p>
                                        <p class="text-sm text-gray-600 mt-2">Cantidad: <span class="font-semibold">${d.cantidad}</span></p>
                                    </div>
                                    <div class="text-right flex-shrink-0">
                                        <p class="text-lg font-bold text-gray-900">$${totalProd.toLocaleString('es-MX', { minimumFractionDigits: 2 })}</p>
                                        <p class="text-xs text-gray-400">($${precio.toLocaleString('es-MX', { minimumFractionDigits: 2 })}/unidad)</p>
                                    </div>
                                </div>
                            </div>
                        `;
                    });

                    modal.classList.remove('hidden');
                } catch (err) {
                    console.error('Error cargando detalle de orden:', err);
                }
            });
        });
    </script>

</body>
</html>
