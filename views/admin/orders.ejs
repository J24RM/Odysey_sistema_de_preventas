<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Historial de ordenes</title>
    <link rel="stylesheet" href="/style_admin_hist_ordenes.css">
</head>

<body>
    <header>
        <div class="logo-area">
            <img src="/img/ppg-logo.svg" alt="Logo PPG" class="logo-header">
        </div>

        <div class="search-bar">
            <input type="text" placeholder="Buscar Orden" />
        </div>

        <div class="header-user">
            <a href="/logout" class="btn-logout">Cerrar sesión</a>
            <div class="user-icon">
                <img src="/img/iconoPerfil.png" alt="Usuario">
            </div>
        </div>
    </header>


    <div class="sidebar">
        <ul class="menu">
            <li><a href="/admin/home">Inicio</a></li>
            <li><a href="/admin/stats">Estadísticas</a></li>
            <li><a href="/admin/orders">Historial de órdenes</a></li>
            <li><a href="/admin/clients">Clientes</a></li>
        </ul>
    </div>



    <div class="contenido">
        <div class="card controles-historial">
            <h2 class="titulo-historial">Historial de órdenes realizadas</h2>

            <div class="controles-row">

                <div class="dropdown">
                    <button class="dropdown-btn">
                        Pedidos más recientes
                        <span class="arrow">▼</span>
                    </button>

                    <div class="dropdown-content">
                        <a href="#">Últimas 12 horas</a>
                        <a href="#">Últimas 24 horas</a>
                        <a href="#">Última semana</a>
                        <a href="#">Último mes</a>
                    </div>
                </div>
                <button class="btn-exportar">Exportar historial</button>
            </div>
        </div>
    </div>

</body>
</html>
