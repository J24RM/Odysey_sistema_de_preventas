<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Historial de órdenes</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Public Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-50">
    <% const pedidos = [
        { orden: 'A0001', fecha: '12 de Marzo de 2026', cliente: 'Concesionario Jurica', total: '$189.00', estatus: 'Pendiente' },
        { orden: 'A0002', fecha: '12 de Marzo de 2026', cliente: 'Concesionario Jurica', total: '$189.00', estatus: 'Confirmada' },
        { orden: 'A0003', fecha: '12 de Marzo de 2026', cliente: 'Concesionario Jurica', total: '$189.00', estatus: 'Confirmada' },
        { orden: 'A0004', fecha: '12 de Marzo de 2026', cliente: 'Concesionario Jurica', total: '$189.00', estatus: 'Confirmada' },
        { orden: 'A0005', fecha: '12 de Marzo de 2026', cliente: 'Concesionario Jurica', total: '$189.00', estatus: 'Confirmada' },
        { orden: 'A0006', fecha: '12 de Marzo de 2026', cliente: 'Concesionario Jurica', total: '$189.00', estatus: 'Cancelada' },
        { orden: 'A0007', fecha: '12 de Marzo de 2026', cliente: 'Concesionario Jurica', total: '$189.00', estatus: 'Confirmada' }
    ]; %>

    <%- include('partials/header.ejs') %>

    <div class="flex min-h-screen flex-col">
        <%- include('partials/sidebar.ejs') %>

        <!-- Main Content -->
        <main class="ml-48 pt-2 px-10 pb-9 flex-1">
            <section class="space-y-6">
                <!-- Header -->
                <div class="flex items-center justify-between">
                    <h1 class="text-3xl font-extrabold text-gray-900">Historial de órdenes</h1>
                    <div class="flex items-center gap-4">
                        <button type="button" class="px-5 py-2.5 bg-white border-2 border-gray-300 rounded-lg font-semibold text-sm text-gray-900 hover:bg-gray-100 transition-all">
                            Exportar todo el historial
                        </button>
                        <div class="relative">
                            <button type="button" class="px-5 py-2.5 bg-white border-2 border-gray-300 rounded-lg font-semibold text-sm text-gray-900 hover:bg-gray-100 transition-all flex items-center gap-2">
                                30 días
                                <span>⌄</span>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Search -->
                <div class="flex-1 relative">
                    <input type="text" placeholder="Buscar historial de pedido" class="w-full px-5 py-2.5 border-2 border-gray-300 rounded-full text-sm font-medium focus:border-blue-600 focus:outline-none transition-colors" />
                </div>

                <p class="text-sm font-semibold text-gray-600 uppercase tracking-wide">Pedidos más recientes:</p>

                <!-- Orders Table -->
                <div class="bg-white rounded-2xl shadow-md overflow-hidden">
                    <!-- Table Header -->
                    <div class="grid grid-cols-5 gap-4 px-6 py-4 border-b-2 border-gray-200 bg-gray-50">
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Orden</span>
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Fecha</span>
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Cliente</span>
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Total</span>
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Estatus</span>
                    </div>

                    <!-- Table Body -->
                    <div class="divide-y divide-gray-200">
                        <% pedidos.forEach((pedido) => { %>
                            <a href="/admin/orders/<%= pedido.orden %>" class="grid grid-cols-5 gap-4 px-6 py-4 items-center hover:bg-blue-50 transition-colors">
                                <span class="font-semibold text-gray-900"><%= pedido.orden %></span>
                                <span class="text-gray-600 text-sm"><%= pedido.fecha %></span>
                                <span class="text-gray-600 text-sm"><%= pedido.cliente %></span>
                                <span class="font-semibold text-gray-900"><%= pedido.total %></span>
                                <div>
                                    <% const statusColors = {
                                        'Pendiente': 'bg-yellow-100 text-yellow-800',
                                        'Cancelada': 'bg-red-100 text-red-800',
                                        'Confirmada': 'bg-green-100 text-green-800'
                                    } %>
                                    <span class="inline-block px-3 py-1 rounded-full text-xs font-bold <%= statusColors[pedido.estatus] || 'bg-gray-100 text-gray-800' %>">
                                        <%= pedido.estatus %>
                                    </span>
                                </div>
                            </a>
                        <% }); %>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <%- include('partials/footer.ejs') %>

</body>
</html>