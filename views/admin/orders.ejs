<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Historial de ordenes</title>
    <link rel="stylesheet" href="/style_admin_hist_ordenes.css">
</head>

<body>
    <% const pedidos = [
        { orden: 'A0001', fecha: '12 de Marzo de 2026', cliente: 'Concesionario Jurica', total: '$189.00', estatus: 'Pendiente' },
        { orden: 'A0002', fecha: '12 de Marzo de 2026', cliente: 'Concesionario Jurica', total: '$189.00', estatus: 'Confirmada' },
        { orden: 'A0003', fecha: '12 de Marzo de 2026', cliente: 'Concesionario Jurica', total: '$189.00', estatus: 'Confirmada' },
        { orden: 'A0004', fecha: '12 de Marzo de 2026', cliente: 'Concesionario Jurica', total: '$189.00', estatus: 'Confirmada' },
        { orden: 'A0005', fecha: '12 de Marzo de 2026', cliente: 'Concesionario Jurica', total: '$189.00', estatus: 'Confirmada' },
        { orden: 'A0006', fecha: '12 de Marzo de 2026', cliente: 'Concesionario Jurica', total: '$189.00', estatus: 'Cancelada' },
        { orden: 'A0007', fecha: '12 de Marzo de 2026', cliente: 'Concesionario Jurica', total: '$189.00', estatus: 'Confirmada' }
    ]; %>

    <header>
        <div class="logo-area">
            <img src="/img/ppg-logo.svg" alt="Logo PPG" class="logo-header">
        </div>

        <div class="search-bar">
            <input type="text" placeholder="Buscar Orden" />
        </div>

        <div class="header-user">
            <a href="/logout" class="btn-logout">Cerrar sesión</a>
            <div class="user-icon">
                <img src="/img/iconoPerfil.png" alt="Usuario">
            </div>
        </div>
    </header>


    <div class="sidebar">
        <ul class="menu">
            <li><a href="/admin/home">Inicio</a></li>
            <li><a href="/admin/stats">Estadísticas</a></li>
            <li><a href="/admin/orders" class="active">Historial de Pedidos</a></li>
            <li><a href="/admin/clients">Clientes</a></li>
        </ul>
    </div>



    <div class="contenido">
        <section class="orders-page">
            <div class="orders-header">
                <h1 class="titulo-historial">Historial de Pedidos</h1>

                <div class="orders-actions">
                    <button class="btn-exportar" type="button">Exportar todo el historial</button>

                    <div class="dropdown dropdown-filter">
                        <button class="dropdown-btn dropdown-btn-large" type="button">
                            30 dias
                            <span class="arrow">⌄</span>
                        </button>

                        <div class="dropdown-content">
                            <a href="#">7 dias</a>
                            <a href="#">30 dias</a>
                            <a href="#">90 dias</a>
                            <a href="#">Ultimo año</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="orders-toolbar">
                <div class="orders-search">
                    <input type="text" placeholder="Buscar historial de pedido">
                    <button type="button" aria-label="Buscar pedido">
                        <span class="search-icon"></span>
                    </button>
                </div>
            </div>

            <p class="orders-label">Pedidos más recientes:</p>

            <section class="orders-table-card">
                <div class="orders-table-head">
                    <span>Orden</span>
                    <span>Fecha</span>
                    <span>Cliente</span>
                    <span>Total</span>
                    <span>Estatus de pedido</span>
                </div>

                <div class="orders-table-body">
                    <% pedidos.forEach((pedido) => { %>
                        <article class="orders-row">
                            <span><%= pedido.orden %></span>
                            <span><%= pedido.fecha %></span>
                            <span><%= pedido.cliente %></span>
                            <span><%= pedido.total %></span>
                            <span class="status-cell">
                                <span class="status-pill <%= pedido.estatus === 'Pendiente' ? 'status-pending' : pedido.estatus === 'Cancelada' ? 'status-cancelled' : 'status-confirmed' %>">
                                    <%= pedido.estatus %>
                                </span>
                            </span>
                        </article>
                    <% }); %>
                </div>
            </section>
        </section>
    </div>

    <footer class="admin-footer">
        <div class="admin-footer-inner">
            <img src="/img/ppg-logo.svg" alt="Logo PPG">
            <p>The PPG logo is a registered trademark and Colorful Communities and We protect and beautify the world are trademarks of PPG Industries Ohio, Inc. © 2026 PPG Industries, Inc.All Rights Reserved</p>
        </div>
    </footer>

</body>
</html>
