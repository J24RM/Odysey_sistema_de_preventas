<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Clientes</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Public Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
    </style>
</head>

<body class="bg-blue-50">
    <%- include('partials/header.ejs') %>

    <div class="flex min-h-screen flex-col">
        <%- include('partials/sidebar.ejs') %>

        <!-- Main Content -->
        <main class="ml-48 pt-2 px-10 pb-9 flex-1">
            <section class="space-y-6">
                <h1 class="text-3xl font-extrabold text-gray-900">Clientes</h1>

                <!-- Toolbar -->
                <div class="flex items-center gap-4">
                    <div class="flex-1 relative">
                        <input id="searchInput" type="text" placeholder="Buscar Cliente" class="w-full px-5 py-2.5 border-2 border-gray-300 rounded text-sm font-medium focus:border-blue-600 focus:outline-none transition-colors" />
                    </div>
                    <button type="button" class="px-6 py-2.5 bg-white border-2 border-gray-300 rounded font-semibold text-sm text-gray-900 hover:bg-gray-100 transition-all">
                        Filtrar
                    </button>
                </div>

                <!-- Clients Table -->
                <div class="bg-white border border-gray-200 overflow-hidden">
                    <!-- Table Header -->
                    <div class="grid grid-cols-4 gap-4 px-6 py-4 border-b-2 border-gray-300 bg-gray-100">
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Perfil</span>
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Nombre</span>
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Correo Electrónico</span>
                        <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Última sesión</span>
                    </div>

                    <!-- Table Body -->
                    <div id="clientesBody" class="divide-y divide-gray-200 flex flex-col">
                        <% if (clientes.length === 0) { %>
                            <p class="px-6 py-8 text-center text-gray-400 text-sm">No hay clientes registrados.</p>
                        <% } %>
                        <% clientes.forEach((cliente) => { %>
                            <a href="/admin/clients/<%= cliente.id_usuario %>"
                               class="cliente-row grid grid-cols-4 gap-4 px-6 py-4 items-center hover:bg-blue-50 transition-colors"
                               data-search="<%= (cliente.nombre || '') + ' ' + cliente.email %>">
                                <div class="w-10 h-10 rounded-full overflow-hidden bg-gray-200 flex-shrink-0">
                                    <img src="/img/iconoPerfil.png" alt="Perfil de cliente" class="w-full h-full object-cover">
                                </div>
                                <span class="font-semibold text-gray-900"><%= cliente.nombre || cliente.email %></span>
                                <span class="text-gray-600 text-sm"><%= cliente.email %></span>
                                <span class="text-gray-500 text-sm">N/A</span>
                            </a>
                        <% }); %>
                    </div>

                    <!-- Sin resultados (oculto por defecto) -->
                    <p id="noResults" class="hidden px-6 py-8 text-center text-gray-400 text-sm">
                        No se encontraron clientes con ese nombre o correo.
                    </p>
                </div>
            </section>
        </main>
    </div>

    <%- include('partials/footer.ejs') %>

    <script>
        const searchInput = document.getElementById('searchInput');
        const rows = document.querySelectorAll('.cliente-row');
        const noResults = document.getElementById('noResults');

        // Banner que indica resultados aproximados
        const fuzzyBanner = document.createElement('p');
        fuzzyBanner.id = 'fuzzyBanner';
        fuzzyBanner.className = 'hidden px-6 py-3 text-center text-blue-500 text-sm bg-blue-50 border-b border-blue-100';
        fuzzyBanner.textContent = 'No se encontró una coincidencia exacta. Mostrando resultados similares:';
        document.getElementById('clientesBody').before(fuzzyBanner);

        /**
         * Devuelve un puntaje de similitud entre 0 y 1.
         * Combina dos criterios:
         *   1. Subsecuencia: todos los caracteres del query aparecen en orden en el texto.
         *   2. Frecuencia de caracteres coincidentes.
         */
        function fuzzyScore(text, query) {
            // Subsecuencia
            let qi = 0;
            for (let i = 0; i < text.length && qi < query.length; i++) {
                if (text[i] === query[qi]) qi++;
            }
            if (qi === query.length) return 1;

            // Frecuencia de caracteres
            const textChars = text.split('');
            let matches = 0;
            for (const ch of query) {
                const idx = textChars.indexOf(ch);
                if (idx !== -1) {
                    matches++;
                    textChars.splice(idx, 1);
                }
            }
            return matches / query.length;
        }

        const FUZZY_THRESHOLD = 0.45;

        searchInput.addEventListener('input', function () {
            const query = this.value.toLowerCase().trim();

            // Resetear estado
            rows.forEach(row => {
                row.style.display = '';
                row.style.order = '';
            });
            noResults.classList.add('hidden');
            fuzzyBanner.classList.add('hidden');

            if (query === '') return;

            // 1. Búsqueda exacta (substring)
            let exactCount = 0;
            rows.forEach(row => {
                const text = row.dataset.search.toLowerCase();
                if (text.includes(query)) {
                    exactCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            if (exactCount > 0) return;

            // 2. Sin resultados exactos → búsqueda aproximada
            const scored = [];
            rows.forEach(row => {
                const text = row.dataset.search.toLowerCase();
                const score = fuzzyScore(text, query);
                scored.push({ row, score });
            });

            // Ordenar por puntaje descendente
            scored.sort((a, b) => b.score - a.score);

            const hasApprox = scored[0].score >= FUZZY_THRESHOLD;

            scored.forEach(({ row, score }, idx) => {
                if (score >= FUZZY_THRESHOLD) {
                    row.style.display = '';
                    row.style.order = idx; // preservar orden de relevancia
                } else {
                    row.style.display = 'none';
                }
            });

            if (hasApprox) {
                fuzzyBanner.classList.remove('hidden');
            } else {
                noResults.classList.remove('hidden');
            }
        });
    </script>

</body>
</html>
