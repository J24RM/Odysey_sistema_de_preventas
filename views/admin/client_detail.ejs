<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Cliente</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Public Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
    </style>
</head>

<body class="bg-blue-50">
    <%- include('partials/header.ejs') %>

    <div class="flex min-h-screen flex-col">
        <%- include('partials/sidebar.ejs') %>

        <!-- Main Content -->
        <main class="ml-48 pt-8 px-6 pb-12 flex-1 flex justify-center items-start">
            <div class="bg-white border border-gray-200 w-full max-w-4xl">

                <!-- Header -->
                <div class="flex items-center justify-between px-8 py-6 border-b border-gray-200">
                    <h2 class="text-2xl font-extrabold text-gray-900">Detalle de Cliente</h2>
                    <a href="/admin/clients" class="text-3xl text-gray-400 hover:text-gray-600 transition-colors font-light leading-none">×</a>
                </div>

                <!-- Profile Section -->
                <div class="px-8 py-6 border-b border-gray-200">
                    <div class="flex items-center gap-6">
                        <div class="w-20 h-20 rounded-full overflow-hidden flex-shrink-0 bg-gray-200">
                            <img src="/img/iconoPerfil.png" alt="Perfil del cliente" class="w-full h-full object-cover">
                        </div>
                        <div class="space-y-1">
                            <p class="text-xl font-extrabold text-gray-900"><%= cliente.nombre %></p>
                            <p class="text-sm text-gray-500"><%= cliente.correo %></p>
                        </div>
                    </div>
                </div>

                <!-- Cuentas y Sucursales Section -->
                <div class="px-8 py-6 border-b border-gray-200">
                    <h3 class="text-base font-bold text-gray-900 mb-4">Cuentas y Sucursales</h3>

                    <% if (cliente.cuentas && cliente.cuentas.length > 0) { %>
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-gray-200">
                                <th class="text-left pb-2 pr-6 font-semibold text-gray-600 w-40">RFC</th>
                                <th class="text-left pb-2 pr-6 font-semibold text-gray-600 w-48">Cuenta</th>
                                <th class="text-left pb-2 font-semibold text-gray-600">Sucursales</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% cliente.cuentas.forEach((cuenta, i) => { %>
                            <tr class="border-b border-gray-100 <%= i % 2 !== 0 ? 'bg-gray-50' : '' %>">
                                <td class="py-3 pr-6 font-mono text-gray-700 align-top text-xs"><%= cuenta.rfc %></td>
                                <td class="py-3 pr-6 font-medium text-gray-900 align-top"><%= cuenta.nombre_dueno %></td>
                                <td class="py-3 align-top">
                                    <% if (cuenta.sucursales && cuenta.sucursales.length > 0) { %>
                                        <div class="flex flex-wrap gap-1">
                                            <% cuenta.sucursales.forEach(s => { %>
                                                <span class="inline-block bg-blue-50 border border-blue-200 text-blue-800 text-xs font-medium px-2 py-0.5 rounded">
                                                    <%= s.nombre_sucursal %>
                                                </span>
                                            <% }); %>
                                        </div>
                                    <% } else { %>
                                        <span class="text-gray-400 text-xs">Sin sucursales</span>
                                    <% } %>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                    <% } else { %>
                    <p class="text-sm text-gray-400">Este cliente no tiene cuentas asignadas.</p>
                    <% } %>
                </div>

                <!-- Orders Section -->
                <div class="px-8 py-6">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-base font-bold text-gray-900">Historial de Pedidos</h3>
                        <% if (total > 0) { %>
                        <span class="text-sm font-semibold text-gray-500 uppercase tracking-wide">
                            Mostrando <%= cliente.pedidos.length %> de <%= total %> &mdash; Página <%= paginaActual %> de <%= Math.max(totalPaginas, 1) %>
                        </span>
                        <% } %>
                    </div>

                    <% if (cliente.pedidos && cliente.pedidos.length > 0) { %>
                    <div class="border border-gray-200 overflow-hidden">
                        <table class="w-full text-sm">
                            <thead class="bg-gray-50 border-b border-gray-200">
                                <tr>
                                    <th class="text-left px-4 py-3 font-semibold text-gray-600">Folio</th>
                                    <th class="text-left px-4 py-3 font-semibold text-gray-600">Fecha</th>
                                    <th class="text-left px-4 py-3 font-semibold text-gray-600">Sucursal</th>
                                    <th class="text-left px-4 py-3 font-semibold text-gray-600">Total</th>
                                    <th class="text-left px-4 py-3 font-semibold text-gray-600">Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% cliente.pedidos.forEach((pedido) => { %>
                                <%
                                    const statusPill = {
                                        'Confirmada': { cls: 'border border-green-300 text-green-900', bg: '#dcfce7' },
                                        'Pendiente':  { cls: 'border border-yellow-300 text-yellow-900', bg: '#fef9c3' },
                                        'Cancelada':  { cls: 'border border-red-300 text-red-900', bg: '#fee2e2' }
                                    }[pedido.estado] || { cls: 'border border-gray-300 text-gray-700', bg: '#f3f4f6' };
                                %>
                                <tr class="border-t border-gray-100 hover:bg-blue-50 transition-colors">
                                    <td class="px-4 py-3 font-semibold text-gray-900"><%= pedido.folio %></td>
                                    <td class="px-4 py-3 text-gray-600"><%= pedido.fecha %></td>
                                    <td class="px-4 py-3 text-gray-600"><%= pedido.sucursal %></td>
                                    <td class="px-4 py-3 font-semibold text-gray-900"><%= pedido.total %></td>
                                    <td class="px-4 py-3">
                                        <span class="inline-block text-xs font-bold uppercase <%= statusPill.cls %>"
                                              style="border-radius:2px; padding:4px 12px; background:<%= statusPill.bg %>;">
                                            <%= pedido.estado %>
                                        </span>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <% if (totalPaginas > 1) { %>
                    <div class="flex items-center justify-center gap-3 pt-5">
                        <% if (paginaActual > 1) { %>
                            <a href="/admin/clients/<%= cliente.id_usuario %>?page=<%= paginaActual - 1 %>"
                               class="px-5 py-2.5 bg-white border-2 border-gray-300 rounded-lg font-semibold text-sm text-gray-700 hover:bg-gray-100 transition-all">
                                ← Anterior
                            </a>
                        <% } else { %>
                            <span class="px-5 py-2.5 bg-gray-100 border-2 border-gray-200 rounded-lg font-semibold text-sm text-gray-400 cursor-not-allowed">
                                ← Anterior
                            </span>
                        <% } %>

                        <span class="px-4 py-2 text-sm font-semibold text-gray-700">
                            Página <%= paginaActual %> de <%= totalPaginas %>
                        </span>

                        <% if (paginaActual < totalPaginas) { %>
                            <a href="/admin/clients/<%= cliente.id_usuario %>?page=<%= paginaActual + 1 %>"
                               class="px-5 py-2.5 bg-white border-2 border-gray-300 rounded-lg font-semibold text-sm text-gray-700 hover:bg-gray-100 transition-all">
                                Siguiente →
                            </a>
                        <% } else { %>
                            <span class="px-5 py-2.5 bg-gray-100 border-2 border-gray-200 rounded-lg font-semibold text-sm text-gray-400 cursor-not-allowed">
                                Siguiente →
                            </span>
                        <% } %>
                    </div>
                    <% } %>

                    <% } else { %>
                    <p class="text-sm text-gray-400">Este cliente aún no tiene pedidos.</p>
                    <% } %>
                </div>

            </div>
        </main>
    </div>

    <%- include('partials/footer.ejs') %>
</body>
</html>
