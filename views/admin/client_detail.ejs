<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Cliente</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Public Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-50">
    <%- include('partials/header.ejs') %>

    <div class="flex min-h-screen flex-col">
        <%- include('partials/sidebar.ejs') %>

        <!-- Main Content -->
        <main class="ml-48 pt-2 px-10 pb-9 flex-1 space-y-6">
            <!-- Modal -->
            <div class="bg-white rounded-2xl shadow-md max-w-3xl">
                <!-- Header -->
                <div class="flex items-center justify-between px-8 py-6 border-b border-gray-200">
                    <h2 class="text-2xl font-extrabold text-gray-900">Cliente</h2>
                    <a href="/admin/clients" class="text-3xl text-gray-400 hover:text-gray-600 transition-colors font-light">
                        ×
                    </a>
                </div>

                <!-- Profile Section -->
                <div class="px-8 py-6 border-b border-gray-200">
                    <div class="flex items-start gap-8">
                        <!-- Avatar -->
                        <div class="w-24 h-24 rounded-full overflow-hidden flex-shrink-0 bg-gray-200">
                            <img src="/img/iconoPerfil.png" alt="Perfil del cliente" class="w-full h-full object-cover">
                        </div>

                        <!-- Info -->
                        <div class="space-y-3 flex-1">
                            <div>
                                <span class="text-sm font-semibold text-gray-600">Nombre:</span>
                                <p class="text-base font-bold text-gray-900"><%= cliente.nombre %></p>
                            </div>
                            <div>
                                <span class="text-sm font-semibold text-gray-600">Correo Electrónico:</span>
                                <p class="text-base font-bold text-gray-900"><%= cliente.correo %></p>
                            </div>
                            <div>
                                <span class="text-sm font-semibold text-gray-600">Teléfono:</span>
                                <p class="text-base font-bold text-gray-900"><%= cliente.telefono %></p>
                            </div>
                            <div>
                                <span class="text-sm font-semibold text-gray-600">Última sesión:</span>
                                <p class="text-base font-bold text-gray-900"><%= cliente.ultimaSesion %></p>
                            </div>

                            <!-- Branch Select -->
                            <div>
                                <label class="text-sm font-semibold text-gray-600 block mb-2">Sucursal:</label>
                                <select class="w-full max-w-xs px-4 py-2.5 border-2 border-gray-300 rounded-lg text-sm focus:border-blue-600 focus:outline-none transition-colors">
                                    <% cliente.sucursales.forEach((sucursal) => { %>
                                        <option><%= sucursal %></option>
                                    <% }); %>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Orders Section -->
                <div class="px-8 py-6">
                    <h3 class="text-lg font-bold text-gray-900 mb-4">Historial de Pedidos</h3>

                    <div class="space-y-0 border border-gray-200 rounded-lg overflow-hidden">
                        <% cliente.pedidos.forEach((pedido, index) => { %>
                            <article class="flex items-center justify-between px-6 py-4 hover:bg-blue-50 transition-colors <%= index !== 0 ? 'border-t border-gray-200' : '' %>">
                                <span class="font-semibold text-gray-900"><%= pedido.folio %></span>
                                <span class="text-gray-600 text-sm"><%= pedido.fecha %></span>
                                <span class="text-gray-600 text-sm"><%= pedido.sucursal %></span>
                                <span class="font-semibold text-gray-900"><%= pedido.total %></span>
                                <% const statusColor = pedido.estado === 'Cancelada' ? 'bg-red-100 text-red-800' : 'bg-green-100 text-green-800' %>
                                <span class="inline-block px-3 py-1 rounded-full text-xs font-bold <%= statusColor %>">
                                    <%= pedido.estado %>
                                </span>
                            </article>
                        <% }); %>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <%- include('partials/footer.ejs') %>
</body>
</html>
