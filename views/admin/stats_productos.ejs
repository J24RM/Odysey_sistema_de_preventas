<!DOCTYPE html>
<html lang="es">

<head>
<meta charset="UTF-8" />
<title>Estadísticas por Producto</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
    * {
        font-family: 'Public Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
</style>
</head>

<body class="bg-gray-50">

<%- include('partials/header.ejs') %>

<%- include('partials/sidebar.ejs') %>

<!-- MAIN CONTENT -->
<main class="ml-48 pt-2 px-10 pb-9 flex-1 min-h-[calc(100vh-70px)]">

    <!-- Tabs -->
    <div class="flex gap-1 border-b-2 border-gray-200 mb-6">
        <a href="/admin/stats" class="tab-link px-5 py-2.5 text-sm font-semibold text-gray-500 hover:text-gray-800 transition-colors border-b-2 border-transparent -mb-[2px]" data-tab="/admin/stats">Generales</a>
        <a href="/admin/stats/sucursales" class="tab-link px-5 py-2.5 text-sm font-semibold text-gray-500 hover:text-gray-800 transition-colors border-b-2 border-transparent -mb-[2px]" data-tab="/admin/stats/sucursales">Sucursales</a>
        <a href="/admin/stats/productos" class="tab-link px-5 py-2.5 text-sm font-semibold text-gray-500 hover:text-gray-800 transition-colors border-b-2 border-transparent -mb-[2px]" data-tab="/admin/stats/productos">Productos</a>
    </div>

    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold">Estadísticas de productos</h1>
        <!-- BARRA BUSCADORA-->
         <div class="flex items-center gap-4">
        <form method="GET" class="flex w-[400px]">
            <input 
                type="text" 
                name="busqueda"
                value="<%= busqueda %>"
                placeholder="Buscar producto..."
                class="w-full px-5 py-2.5 border-2 border-gray-300 rounded-full text-sm font-medium focus:border-blue-600 focus:outline-none transition-colors"
            />
            <input type="hidden" name="periodo" value="<%= periodo %>">
        </form>
        </div>

  

        <div class="flex gap-3">

            <!-- FILTRO -->
            <form method="GET">
                <input type="hidden" name="busqueda" value="<%= busqueda %>">

                <select 
                    name="periodo"
                    onchange="this.form.submit()"
                    class="border rounded-lg px-3 py-2 text-sm"
                >
                    <option value="semana" <%= periodo === 'semana' ? 'selected' : '' %>>Esta Semana</option>
                    <option value="mes" <%= periodo === 'mes' ? 'selected' : '' %>>Último Mes</option>
                </select>
            </form>

            <a 
                href="/admin/stats/productos/exportar?periodo=<%= periodo %>&busqueda=<%= busqueda %>"
                class="border px-4 py-2 rounded-lg text-sm hover:bg-gray-100"
            >
                Exportar
            </a>

        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-100 text-gray-600">
                <tr>
                    <th class="text-left px-6 py-4">Producto</th>
                    <th class="text-center px-6 py-4">Cantidad Ordenada</th>
                    <th class="text-center px-6 py-4">Ventas</th>
                </tr>
            </thead>

            <tbody>
                <% productos.forEach(p => { %>
                    <tr onclick="window.location='/admin/stats/productos/<%= p.id_producto %>'"
                        class="cursor-pointer border-t hover:bg-gray-50 transition">

                        <!-- Producto -->
                        <td class="px-6 py-4 flex items-center gap-4">
                            <img src="/uploads/<%= p.url_imagen %>" class="w-12 h-12 object-cover rounded">
                            <span class="font-semibold"><%= p.nombre %></span>
                        </td>

                        <!-- Cantidad -->
                        <td class="px-6 py-4 text-center">
                            <div class="font-bold text-lg"><%= p.cantidad %></div>

                            <div class="text-sm font-medium
                                <%= p.porcentajeCantidad >= 0 ? 'text-green-600' : 'text-red-500' %>">
                                
                                <% if (p.porcentajeCantidad >= 0) { %>
                                    ▲ <%= Math.round(p.porcentajeCantidad) %>%
                                <% } else { %>
                                    ▼ <%= Math.abs(Math.round(p.porcentajeCantidad)) %>%
                                <% } %>
                            </div>
                        </td>

                        <!-- Ventas -->
                        <td class="px-6 py-4 text-center">
                            <div class="font-bold text-lg">
                                $<%= p.ventas.toLocaleString() %>
                            </div>

                            <div class="text-sm font-medium
                                <%= p.porcentajeVentas >= 0 ? 'text-green-600' : 'text-red-500' %>">
                                
                                <% if (p.porcentajeVentas >= 0) { %>
                                    ▲ <%= Math.round(p.porcentajeVentas) %>%
                                <% } else { %>
                                    ▼ <%= Math.abs(Math.round(p.porcentajeVentas)) %>%
                                <% } %>
                            </div>
                        </td>

                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

</main>

<%- include('partials/footer.ejs') %>

<script>
    const currentPath = window.location.pathname;
    document.querySelectorAll('.tab-link').forEach(tab => {
        if (tab.dataset.tab === currentPath) {
            tab.classList.add('border-blue-600', 'text-blue-600');
            tab.classList.remove('text-gray-500');
        }
    });
</script>

</body>

</html>
