<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Configuración de Campaña</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { font-family: 'Public Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
        .preview-img { max-height: 120px; object-fit: contain; border: 1px solid #e5e7eb; border-radius: 6px; }
    </style>
</head>
<body class="bg-blue-50">
    <%- include('partials/header.ejs') %>

    <div class="flex min-h-screen flex-col">
        <%- include('partials/sidebar.ejs') %>

        <main class="ml-48 pt-6 px-10 pb-12 flex-1">
            <div class="max-w-4xl mx-auto">

            <h1 class="text-2xl font-extrabold text-gray-900 mb-1">Configuración de Campaña</h1>
            <p class="text-sm text-gray-500 mb-8">Controla el temporizador, estado, banners y colores de la campaña activa.</p>

            <% if (mensaje) { %>
                <div class="mb-6 px-4 py-3 bg-green-50 border border-green-300 text-green-800 rounded text-sm font-semibold">
                    <%= mensaje %>
                </div>
            <% } %>
            <% if (error) { %>
                <div class="mb-6 px-4 py-3 bg-red-50 border border-red-300 text-red-800 rounded text-sm font-semibold">
                    <%= error %>
                </div>
            <% } %>

            <form action="/admin/campania" method="POST" enctype="multipart/form-data" class="space-y-8">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <!-- ─── 1. NOMBRE Y TEMPORIZADOR ─── -->
                <section class="bg-white border border-gray-200 rounded p-6">
                    <h2 class="text-base font-bold text-gray-900 mb-5 flex items-center gap-2">
                        <span class="w-6 h-6 rounded-full bg-blue-700 text-white text-xs flex items-center justify-center font-bold">1</span>
                        Nombre y Temporizador
                    </h2>
                    <div class="grid grid-cols-2 gap-6">
                        <div>
                            <label class="block text-xs font-bold text-gray-600 uppercase tracking-wide mb-1">Nombre de la campaña</label>
                            <input type="text" name="nombre"
                                value="<%= config.nombre || '' %>"
                                placeholder="Ej. Mundial 2026"
                                class="w-full px-3 py-2.5 border border-gray-300 rounded text-sm focus:border-blue-600 focus:outline-none">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-gray-600 uppercase tracking-wide mb-1">Fecha y hora de fin</label>
                            <input type="datetime-local" name="fecha_de_fin"
                                value="<%= config.fecha_de_fin ? new Date(config.fecha_de_fin).toISOString().slice(0,16) : '' %>"
                                class="w-full px-3 py-2.5 border border-gray-300 rounded text-sm focus:border-blue-600 focus:outline-none">
                            <p class="text-xs text-gray-400 mt-1">El temporizador de admin y cliente contará hacia esta fecha.</p>
                        </div>
                    </div>
                </section>

                <!-- ─── 2. ESTADO ACTIVO ─── -->
                <section class="bg-white border border-gray-200 rounded p-6">
                    <h2 class="text-base font-bold text-gray-900 mb-5 flex items-center gap-2">
                        <span class="w-6 h-6 rounded-full bg-blue-700 text-white text-xs flex items-center justify-center font-bold">2</span>
                        Estado de la Campaña
                    </h2>
                    <div class="flex items-center gap-8">
                        <label class="flex items-center gap-3 cursor-pointer">
                            <input type="radio" name="activo" value="true"
                                <%= (config.activo === true) ? 'checked' : '' %>
                                class="w-4 h-4 accent-blue-700">
                            <span class="flex items-center gap-2 text-sm font-semibold text-gray-800">
                                <span class="w-2.5 h-2.5 rounded-full bg-green-500 inline-block"></span>
                                Activa
                            </span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer">
                            <input type="radio" name="activo" value="false"
                                <%= (config.activo !== true) ? 'checked' : '' %>
                                class="w-4 h-4 accent-blue-700">
                            <span class="flex items-center gap-2 text-sm font-semibold text-gray-800">
                                <span class="w-2.5 h-2.5 rounded-full bg-red-400 inline-block"></span>
                                Inactiva
                            </span>
                        </label>
                    </div>
                    <p class="text-xs text-gray-400 mt-3">Cuando está inactiva, el banner de preventa no se muestra a los clientes.</p>
                </section>

                <!-- ─── 3. BANNERS ─── -->
                <section class="bg-white border border-gray-200 rounded p-6">
                    <h2 class="text-base font-bold text-gray-900 mb-5 flex items-center gap-2">
                        <span class="w-6 h-6 rounded-full bg-blue-700 text-white text-xs flex items-center justify-center font-bold">3</span>
                        Banners e Imágenes
                    </h2>
                    <div class="grid grid-cols-2 gap-8">
                        <!-- Banner login -->
                        <div>
                            <label class="block text-xs font-bold text-gray-600 uppercase tracking-wide mb-2">Imagen de fondo (Login)</label>
                            <% if (config.banner_login_url) { %>
                                <img src="/uploads/<%= config.banner_login_url %>" alt="Banner login" class="preview-img mb-3 block">
                            <% } else { %>
                                <img src="/img/fondoLogin.jpg" alt="Banner login actual" class="preview-img mb-3 block opacity-60">
                                <p class="text-xs text-gray-400 mb-2">Imagen actual (predeterminada)</p>
                            <% } %>
                            <input type="file" name="banner_login" accept="image/png,image/jpeg"
                                class="w-full text-sm text-gray-600 file:mr-3 file:py-2 file:px-4 file:border file:border-gray-300 file:rounded file:text-xs file:font-semibold file:bg-gray-50 hover:file:bg-gray-100 cursor-pointer">
                            <p class="text-xs text-gray-400 mt-1">Reemplaza el fondo de la pantalla de inicio de sesión.</p>
                        </div>
                        <!-- Banner timer -->
                        <div>
                            <label class="block text-xs font-bold text-gray-600 uppercase tracking-wide mb-2">Imagen junto al temporizador</label>
                            <% if (config.banner_general_url) { %>
                                <img src="/uploads/<%= config.banner_general_url %>" alt="Banner timer" class="preview-img mb-3 block">
                            <% } else { %>
                                <img src="/img/niñoMundial.png" alt="Imagen timer actual" class="preview-img mb-3 block opacity-60" onerror="this.src='/img/botePintura.png'">
                                <p class="text-xs text-gray-400 mb-2">Imagen actual (predeterminada)</p>
                            <% } %>
                            <input type="file" name="banner_timer" accept="image/png,image/jpeg"
                                class="w-full text-sm text-gray-600 file:mr-3 file:py-2 file:px-4 file:border file:border-gray-300 file:rounded file:text-xs file:font-semibold file:bg-gray-50 hover:file:bg-gray-100 cursor-pointer">
                            <p class="text-xs text-gray-400 mt-1">Aparece junto al temporizador en admin y cliente.</p>
                        </div>
                    </div>
                </section>


                <div class="flex justify-end">
                    <button type="submit"
                        class="px-8 py-3 bg-blue-700 text-white font-bold text-sm rounded hover:bg-blue-800 transition-colors">
                        Guardar configuración
                    </button>
                </div>
            </form>
            </div>
        </main>
    </div>

    <%- include('partials/footer.ejs') %>


</body>
</html>