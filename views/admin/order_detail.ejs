<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Detalle de orden</title>
    <link rel="stylesheet" href="/style_admin_order_detail.css">
</head>

<body>
    <header>
        <div class="logo-area">
            <img src="/img/ppg-logo.svg" alt="Logo PPG" class="logo-header">
        </div>

        <div class="search-bar">
            <input type="text" placeholder="Buscar Producto" />
        </div>

        <div class="header-user">
            <a href="/logout" class="btn-logout">Cerrar sesión</a>
            <div class="user-icon">
                <img src="/img/iconoPerfil.png" alt="Usuario">
            </div>
        </div>
    </header>

    <div class="layout">
        <aside>
            <nav class="menu">
                <a href="/admin/home">Inicio</a>
                <a href="/admin/stats">Estadísticas</a>
                <a href="/admin/orders" class="active">Historial de órdenes</a>
                <a href="/admin/clients">Clientes</a>
            </nav>
        </aside>

        <main>
            <a class="back-link" href="/admin/orders">
                <span class="back-arrow">←</span>
                <span>Volver</span>
            </a>

            <h1 class="detail-title">Detalle de orden</h1>

            <section class="order-summary-card">
                <div class="summary-grid">
                    <div class="summary-column">
                        <p>Folio: <span><%= orden.folio %></span></p>
                        <p>Fecha: <span><%= orden.fecha %></span></p>
                        <p class="summary-user">Usuario que ordeno: <span><%= orden.usuario %></span></p>
                    </div>

                    <div class="summary-column">
                        <p>Sucursal: <span><%= orden.sucursal %></span></p>
                        <p class="summary-linklike">Total de productos: <span><%= orden.totalProductos %></span></p>
                    </div>

                    <div class="summary-column summary-column-right">
                        <div class="summary-status-line">
                            <span>Estado de la orden:</span>
                            <span class="summary-status-pill"><%= orden.estado %></span>
                        </div>
                        <p>Subtotal: <span><%= orden.subtotal %></span></p>
                        <button type="button" class="btn-export">Exportar</button>
                    </div>
                </div>
            </section>

            <h2 class="products-title">Productos</h2>

            <section class="order-products-card">
                <% orden.productos.forEach((producto, index) => { %>
                    <article class="order-product-row <%= producto.destacado ? 'order-product-row-highlight' : '' %>">
                        <div class="product-image-box">
                            <img src="<%= producto.imagen %>" alt="<%= producto.nombre %>">
                        </div>

                        <div class="product-main-info">
                            <p class="product-name"><%= producto.nombre %></p>
                            <div class="product-qty-box">Cantidad: <span><%= producto.cantidad %></span></div>
                        </div>

                        <div class="product-price-box">
                            <p class="product-total">$ <%= producto.total %></p>
                            <p class="product-unit">($ <%= producto.precioUnitario %>/ unidad)</p>
                        </div>
                    </article>

                    <% if (index !== orden.productos.length - 1) { %>
                        <div class="product-divider"></div>
                    <% } %>
                <% }); %>
            </section>
        </main>
    </div>

    <footer class="admin-footer">
        <div class="admin-footer-inner">
            <img src="/img/ppg-logo.svg" alt="Logo PPG">
            <p>The PPG logo is a registered trademark and Colorful Communities and We protect and beautify the world are trademarks of PPG Industries Ohio, Inc. © 2026 PPG Industries, Inc.All Rights Reserved</p>
        </div>
    </footer>
</body>

</html>
