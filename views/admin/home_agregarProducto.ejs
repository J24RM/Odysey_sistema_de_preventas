<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Agregar Producto</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Public Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-50">

    <%- include('partials/header.ejs') %>

    <div class="flex min-h-screen flex-col">
        <%- include('partials/sidebar.ejs') %>

        <!-- Main Content -->
        <main class="ml-48 pt-2 px-10 pb-9 flex-1 max-w-6xl">
            <!-- Back Button -->
            <a href="/admin/home" class="inline-flex items-center gap-2 text-blue-600 font-semibold hover:text-blue-700 transition-colors mb-8">
                <span>←</span>
                <span>Volver al inicio</span>
            </a>

            <!-- Page Title -->
            <h1 class="text-4xl font-extrabold text-gray-900 mb-10">Agregar Producto</h1>

            <!-- Card Container -->
            <div class="bg-white rounded-2xl shadow-md p-8">
                <!-- Tabs -->
                <div class="flex border-b border-gray-200 mb-8">
                    <button class="product-tab-btn active py-4 px-8 font-semibold text-lg text-gray-900 border-b-4 border-b-blue-600 transition-all hover:text-blue-600" data-product-tab="manual" type="button">
                        Agregar producto manualmente
                    </button>
                    <button class="product-tab-btn py-4 px-8 font-semibold text-lg text-gray-500 border-b-4 border-b-transparent transition-all hover:text-gray-900" data-product-tab="bulk" type="button">
                        Carga masiva de productos
                    </button>
                </div>

                <!-- Manual Tab -->
                <div class="product-panel active space-y-6" data-product-panel="manual">
                    <form class="space-y-6">
                        <!-- Full Width Field -->
                        <div class="space-y-2">
                            <label for="productName" class="block text-sm font-semibold text-gray-900">Nombre del producto:</label>
                            <input id="productName" type="text" placeholder="Ingresa el nombre del producto" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg text-sm focus:border-blue-600 focus:outline-none transition-colors" />
                        </div>

                        <div class="space-y-2">
                            <label for="productDescription" class="block text-sm font-semibold text-gray-900">Descripción:</label>
                            <input id="productDescription" type="text" placeholder="Ingresa la descripción completa del producto" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg text-sm focus:border-blue-600 focus:outline-none transition-colors" />
                        </div>

                        <!-- Grid 3 Columns -->
                        <div class="grid grid-cols-3 gap-6">
                            <div class="space-y-2">
                                <label for="productKey" class="block text-sm font-semibold text-gray-900">Clave del producto:</label>
                                <input id="productKey" type="text" placeholder="Ingresa la clave" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg text-sm focus:border-blue-600 focus:outline-none transition-colors" />
                            </div>

                            <div class="space-y-2">
                                <label for="saleUnit" class="block text-sm font-semibold text-gray-900">Unidad de venta:</label>
                                <select id="saleUnit" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg text-sm focus:border-blue-600 focus:outline-none transition-colors">
                                    <option selected disabled>Selecciona la unidad</option>
                                    <option>Pieza</option>
                                    <option>Caja</option>
                                    <option>Paquete</option>
                                    <option>Litro</option>
                                </select>
                            </div>

                            <div class="space-y-2">
                                <label for="measureUnit" class="block text-sm font-semibold text-gray-900">Unidad de medida:</label>
                                <select id="measureUnit" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg text-sm focus:border-blue-600 focus:outline-none transition-colors">
                                    <option selected disabled>Selecciona la unidad</option>
                                    <option>Mililitros</option>
                                    <option>Litros</option>
                                    <option>Kilogramos</option>
                                    <option>Gramos</option>
                                </select>
                            </div>
                        </div>

                        <!-- Bottom Grid -->
                        <div class="grid grid-cols-3 gap-6">
                            <!-- Image Upload -->
                            <div class="space-y-2">
                                <label for="productImage" class="block text-sm font-semibold text-gray-900">Imagen:</label>
                                <label class="block w-full p-6 border-2 border-dashed border-gray-300 rounded-lg text-center cursor-pointer hover:border-blue-600 hover:bg-blue-50 transition-all">
                                    <span class="text-sm text-gray-600 font-medium">Arrastra la imagen</span>
                                    <input id="productImage" type="file" accept="image/*" hidden />
                                </label>
                            </div>

                            <!-- Volume & Active Toggle -->
                            <div class="space-y-4">
                                <div class="space-y-2">
                                    <label for="productVolume" class="block text-sm font-semibold text-gray-900">Volumen:</label>
                                    <input id="productVolume" type="text" placeholder="Ingresa el volumen" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg text-sm focus:border-blue-600 focus:outline-none transition-colors" />
                                </div>

                                <div class="space-y-2">
                                    <span class="block text-sm font-semibold text-gray-900">Marcar producto activo:</span>
                                    <div class="flex items-center gap-3">
                                        <span class="text-sm text-gray-600">No</span>
                                        <label class="relative inline-flex items-center cursor-pointer">
                                            <input type="checkbox" class="sr-only peer" checked />
                                            <div class="w-11 h-6 bg-gray-300 peer-checked:bg-blue-600 rounded-full peer-checked:after:translate-x-5 after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all"></div>
                                        </label>
                                        <span class="text-sm text-gray-600">Sí</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Weight & Submit -->
                            <div class="space-y-4">
                                <div class="space-y-2">
                                    <label for="productWeight" class="block text-sm font-semibold text-gray-900">Peso:</label>
                                    <input id="productWeight" type="text" placeholder="Ingresa el peso (kg)" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg text-sm focus:border-blue-600 focus:outline-none transition-colors" />
                                </div>

                                <div class="space-y-2">
                                    <button class="w-full py-3 bg-blue-600 text-white font-bold text-sm rounded-lg hover:bg-blue-700 transition-all" type="submit">
                                        Agregar
                                    </button>
                                    <p class="text-xs text-gray-500 text-center">Llena correctamente todos los campos</p>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Bulk Tab -->
                <div class="product-panel hidden space-y-6" data-product-panel="bulk">
                    <div class="text-center space-y-6 py-12">
                        <h3 class="text-2xl font-bold text-gray-900">Carga masiva de productos</h3>
                        <p class="text-gray-600">Sube un archivo con el listado de productos para registrar varios elementos al mismo tiempo.</p>
                        <label class="block p-12 border-2 border-dashed border-gray-300 rounded-lg text-center cursor-pointer hover:border-blue-600 hover:bg-blue-50 transition-all">
                            <span class="text-base text-gray-600 font-medium">Haz clic o arrastra tu archivo CSV o Excel</span>
                            <input id="bulkFile" type="file" accept=".csv,.xlsx,.xls" hidden />
                        </label>
                        <button class="mx-auto px-8 py-3 bg-blue-600 text-white font-bold text-sm rounded-lg hover:bg-blue-700 transition-all" type="button">
                            Subir archivo
                        </button>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <%- include('partials/footer.ejs') %>

    <script>
        const productTabs = document.querySelectorAll('[data-product-tab]');
        const productPanels = document.querySelectorAll('[data-product-panel]');

        productTabs.forEach((tab) => {
            tab.addEventListener('click', () => {
                const targetPanel = tab.dataset.productTab;

                productTabs.forEach((item) => {
                    item.classList.toggle('border-b-blue-600', item === tab);
                    item.classList.toggle('border-b-transparent', item !== tab);
                    item.classList.toggle('text-gray-900', item === tab);
                    item.classList.toggle('text-gray-500', item !== tab);
                });

                productPanels.forEach((panel) => {
                    if (panel.dataset.productPanel === targetPanel) {
                        panel.classList.remove('hidden');
                    } else {
                        panel.classList.add('hidden');
                    }
                });
            });
        });
    </script>

</body>
</html>
