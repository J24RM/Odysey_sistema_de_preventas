<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/svg+xml" href="/img/PPG_Logo2.svg">
    <title>Agregar Producto</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { font-family: 'Public Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
    </style>
</head>

<body class="bg-blue-50">

    <%- include('partials/header.ejs') %>

    <div class="flex min-h-screen flex-col">
        <%- include('partials/sidebar.ejs') %>

        <main class="ml-48 pt-4 px-10 pb-9 flex-1">
            <div class="max-w-4xl mx-auto">

                <!-- Volver al inicio -->
                <a href="/admin/home" class="inline-flex items-center gap-2 text-blue-600 font-semibold hover:text-blue-700 transition-colors mb-6">
                    ← Volver al inicio
                </a>

                <!-- Titulo de la pestaña -->
                <h1 class="text-4xl font-extrabold text-gray-900 mb-8">Agregar Producto</h1>

                <!-- Card -->
                <div class="bg-white border border-gray-200 rounded p-8">

                    <!-- Secciones -->
                    <div class="flex border-b border-gray-200 mb-8">
                        <button class="product-tab-btn py-4 px-8 font-semibold text-lg text-gray-900 border-b-4 border-b-blue-600 transition-all hover:text-blue-600"
                            data-product-tab="manual" type="button">
                            Agregar producto manualmente
                        </button>
                        <button class="product-tab-btn py-4 px-8 font-semibold text-lg text-gray-500 border-b-4 border-b-transparent transition-all hover:text-gray-900"
                            data-product-tab="bulk" type="button">
                            Carga masiva de productos
                        </button>
                    </div>

                    <!-- Error Banner (manual) -->
                    <% if (error) { %>
                    <div class="mb-6 p-4 bg-red-50 border-l-4 border-red-500">
                        <p class="text-red-700 font-semibold"><%= error %></p>
                    </div>
                    <% } %>

                    <!--Carga manual -->
                    <div class="product-panel space-y-6" data-product-panel="manual">
                        <form class="space-y-6" action="/admin/agregar_producto" method="POST" enctype="multipart/form-data">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                            <div class="space-y-2">
                                <label for="productName" class="block text-sm font-semibold text-gray-900">Nombre del producto:</label>
                                <input id="productName" name="nombre" type="text"
                                    placeholder="Ingresa el nombre del producto"
                                    value="<%= formulario?.nombre ?? '' %>"
                                    class="w-full px-4 py-3 border-2 border-gray-300 rounded text-sm shadow-sm focus:border-blue-600 focus:outline-none transition-colors" />
                            </div>

                            <div class="space-y-2">
                                <label for="productDescription" class="block text-sm font-semibold text-gray-900">Descripción:</label>
                                <input id="productDescription" name="descripcion" type="text"
                                    placeholder="Ingresa la descripción completa del producto"
                                    value="<%= formulario?.descripcion ?? '' %>"
                                    class="w-full px-4 py-3 border-2 border-gray-300 rounded text-sm shadow-sm focus:border-blue-600 focus:outline-none transition-colors" />
                            </div>

                            <div class="space-y-2">
                                <label for="campania" class="block text-sm font-semibold text-gray-900">Campaña:</label>
                                <select id="campania" name="id_campania"
                                    class="w-full px-4 py-3 border-2 border-gray-300 rounded text-sm shadow-sm focus:border-blue-600 focus:outline-none transition-colors">
                                    <option value="" data-activo="true">Selecciona la campaña a a que pertenece el producto:</option>
                                    <% campanias.forEach(c => { %>
                                    <option value="<%= c.id_campania %>"
                                        data-activo="<%= c.activo ? 'true' : 'false' %>"
                                        <%= formulario?.id_campania == c.id_campania ? 'selected' : '' %>>
                                        <%= c.nombre %><%= c.activo ? ' (activa)' : '' %>
                                    </option>
                                    <% }) %>
                                </select>
                            </div>

                            <!-- Grid 3 columnas -->
                            <div class="grid grid-cols-3 gap-6">
                                <div class="space-y-2">
                                    <label for="productKey" class="block text-sm font-semibold text-gray-900">Clave del producto:</label>
                                    <input id="productKey" name="clave" type="text"
                                        placeholder="Ingresa la clave alfanumérica"
                                        value="<%= formulario?.clave ?? '' %>" maxlength="12"
                                        class="w-full px-4 py-3 border-2 border-gray-300 rounded text-sm shadow-sm focus:border-blue-600 focus:outline-none transition-colors" />
                                </div>

                                <div class="space-y-2">
                                    <label for="saleUnit" class="block text-sm font-semibold text-gray-900">Unidad de venta:</label>
                                    <select id="saleUnit" name="unidad_venta"
                                        class="w-full px-4 py-3 border-2 border-gray-300 rounded text-sm shadow-sm focus:border-blue-600 focus:outline-none transition-colors">
                                        <option selected disabled>Selecciona la unidad</option>
                                        <option value="Rollo"  <%= formulario?.unidad_venta === 'Rollo'  ? 'selected' : '' %>>Rollo</option>
                                        <option value="Kit"    <%= formulario?.unidad_venta === 'Kit'    ? 'selected' : '' %>>Kit</option>
                                        <option value="Caja"   <%= formulario?.unidad_venta === 'Caja'   ? 'selected' : '' %>>Caja</option>
                                        <option value="Pieza"  <%= formulario?.unidad_venta === 'Pieza'  ? 'selected' : '' %>>Pieza</option>
                                    </select>
                                </div>

                                <div class="space-y-2">
                                    <label for="measureUnit" class="block text-sm font-semibold text-gray-900">Unidad de medida:</label>
                                    <select id="measureUnit" name="unidad_medida"
                                        class="w-full px-4 py-3 border-2 border-gray-300 rounded text-sm shadow-sm focus:border-blue-600 focus:outline-none transition-colors">
                                        <option selected disabled>Selecciona la unidad</option>
                                        <option value="Litros"      <%= formulario?.unidad_medida === 'Litros'      ? 'selected' : '' %>>Litros</option>
                                        <option value="Mililitros"  <%= formulario?.unidad_medida === 'Mililitros'  ? 'selected' : '' %>>Mililitros</option>
                                        <option value="Kilogramos"  <%= formulario?.unidad_medida === 'Kilogramos'  ? 'selected' : '' %>>Kilogramos</option>
                                        <option value="Gramos"      <%= formulario?.unidad_medida === 'Gramos'      ? 'selected' : '' %>>Gramos</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Grid inferior -->
                            <div class="grid grid-cols-3 gap-6">

                                <!-- Upload imagen -->
                                <div class="space-y-2">
                                    <label for="productImage" class="block text-sm font-semibold text-gray-900">Imagen:</label>
                                    <label id="imageUploadLabel"
                                        class="block w-full p-4 border-2 border-dashed rounded text-center shadow-sm cursor-pointer hover:border-blue-600 hover:bg-blue-50 transition-all <%= formulario?.imagen_temp ? 'border-green-500 bg-green-50' : 'border-gray-300' %>">
                                        <img id="imagePreview" class="<%= formulario?.imagen_temp ? '' : 'hidden' %> mx-auto mb-2 h-20 w-auto object-contain rounded"
                                            src="<%= formulario?.imagen_temp ? '/uploads/' + formulario.imagen_temp : '' %>" alt="preview" />
                                        <span id="imageUploadText" class="text-sm text-gray-600 font-medium">
                                            <%= formulario?.imagen_temp ? formulario.imagen_temp : 'Arrastra la imagen' %>
                                        </span>
                                        <input id="productImage" name="imagen" type="file" accept="image/png,image/jpg,image/jpeg" hidden />
                                    </label>
                                    <% if (formulario?.imagen_temp) { %>
                                        <input type="hidden" name="imagen_temp" value="<%= formulario.imagen_temp %>">
                                    <% } %>
                                </div>

                                <!-- Precio y toggle activo -->
                                <div class="space-y-4">
                                    <div class="space-y-2">
                                        <label for="productPrice" class="block text-sm font-semibold text-gray-900">Precio unitario:</label>
                                        <input id="productPrice" name="precio_unitario" type="number"
                                            placeholder="Ingresa el precio"
                                            value="<%= formulario?.precio_unitario ?? '' %>" min="0" step="0.01"
                                            class="w-full px-4 py-3 border-2 border-gray-300 rounded text-sm shadow-sm focus:border-blue-600 focus:outline-none transition-colors" />
                                    </div>

                                    <div class="space-y-2">
                                        <span class="block text-sm font-semibold text-gray-900">Marcar producto activo:</span>
                                        <div class="flex items-center gap-3">
                                            <span class="text-sm text-gray-600">No</span>
                                            <label class="relative inline-flex items-center cursor-pointer" id="activeToggleLabel">
                                                <input id="activeToggle" type="checkbox" name="activo" value="on"
                                                    class="sr-only peer" <%= formulario?.activo === 'on' ? 'checked' : '' %> />
                                                <div class="w-11 h-6 bg-gray-300 peer-checked:bg-blue-600 rounded-full
                                                    peer-checked:after:translate-x-5
                                                    after:content-[''] after:absolute after:top-0.5 after:left-0.5
                                                    after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all"></div>
                                            </label>
                                            <span class="text-sm text-gray-600">Sí</span>
                                        </div>
                                        <p id="activoWarning" class="hidden text-xs text-amber-600 font-medium">
                                            La campaña seleccionada no está activa; el producto se guardará como inactivo.
                                        </p>
                                    </div>
                                </div>

                                <!-- Peso y botón -->
                                <div class="space-y-4">
                                    <div class="space-y-2">
                                        <label for="productWeight" class="block text-sm font-semibold text-gray-900">Peso (kg):</label>
                                        <input id="productWeight" name="peso" type="number"
                                            placeholder="Ingresa el peso"
                                            value="<%= formulario?.peso ?? '' %>" min="0" step="0.01"
                                            class="w-full px-4 py-3 border-2 border-gray-300 rounded text-sm shadow-sm focus:border-blue-600 focus:outline-none transition-colors" />
                                    </div>

                                    <div class="space-y-2">
                                        <button id="submitBtn"
                                            class="w-full py-3 bg-blue-600 text-white font-bold text-sm rounded hover:bg-blue-700 transition-colors"
                                            type="button">
                                            Agregar
                                        </button>
                                        <p class="text-xs text-gray-500 text-center">Llena correctamente todos los campos</p>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>

                    <!-- Bulk Tab -->
                    <div class="product-panel hidden" data-product-panel="bulk">

                        <% if (errorBulk) { %>
                        <div class="mb-6 p-4 bg-red-50 border-l-4 border-red-500">
                            <p class="text-red-700 font-semibold"><%= errorBulk %></p>
                        </div>
                        <% } %>

                        <% if (mensajeBulk) { %>
                        <div class="mb-6 p-4 bg-green-50 border-l-4 border-green-500">
                            <p class="text-green-700 font-semibold">Se guardaron <%= mensajeBulk.cantidad %> imagen(es) correctamente.</p>
                            <ul class="mt-2 text-sm text-green-600 list-disc list-inside">
                                <% mensajeBulk.nombres.forEach(n => { %><li><%= n %></li><% }) %>
                            </ul>
                        </div>
                        <% } %>

                        <% if (resultadoCSV) { %>
                            <% if (resultadoCSV.insertados.length > 0) { %>
                            <div class="mb-4 p-4 bg-green-50 border-l-4 border-green-500">
                                <p class="text-green-700 font-semibold">Se insertaron <%= resultadoCSV.insertados.length %> producto(s) correctamente.</p>
                                <ul class="mt-2 text-sm text-green-600 list-disc list-inside">
                                    <% resultadoCSV.insertados.forEach(n => { %><li><%= n %></li><% }) %>
                                </ul>
                            </div>
                            <% } %>
                            <% if (resultadoCSV.errores.length > 0) { %>
                            <div class="mb-4 p-4 bg-red-50 border-l-4 border-red-500">
                                <p class="text-red-700 font-semibold">Se encontraron <%= resultadoCSV.errores.length %> error(es) en el archivo:</p>
                                <ul class="mt-2 text-sm text-red-600 list-disc list-inside">
                                    <% resultadoCSV.errores.forEach(e => { %><li><%= e %></li><% }) %>
                                </ul>
                            </div>
                            <% } %>
                        <% } %>

                        <form action="/admin/cargar_bulk" method="POST" enctype="multipart/form-data" id="bulkForm">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <div class="grid grid-cols-2 gap-6">

                                <!-- Cargar archivo -->
                                <div class="border border-gray-200 rounded p-6 space-y-4 shadow-sm">
                                    <div>
                                        <h3 class="text-xl font-bold text-gray-900">Cargar archivo</h3>
                                        <p class="text-sm text-gray-500 mt-1">Sube un CSV o Excel con el listado de productos.</p>
                                        <p class="text-xs text-gray-400 mt-1">Columnas requeridas (en orden): <span class="font-mono">nombre, descripcion, url_imagen, unidad_venta, unidad_medida, peso, precio_unitario, activo, clave</span></p>
                                        <p class="text-xs text-gray-400 mt-0.5">La clave no debe exceder 7 caracteres. La url_imagen debe coincidir con el nombre del archivo subido en "Subir imágenes".</p>
                                    </div>
                                    <label id="csvDropZone"
                                        class="flex flex-col items-center justify-center gap-2 p-10 border-2 border-dashed border-gray-300 rounded shadow-sm cursor-pointer hover:border-blue-600 hover:bg-blue-50 transition-all">
                                        <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                                        </svg>
                                        <span id="csvLabel" class="text-sm text-gray-600 font-medium text-center">Haz clic o arrastra tu archivo CSV o Excel</span>
                                        <input id="bulkFile" name="archivoCSV" type="file" accept=".csv,.xlsx,.xls" hidden />
                                    </label>
                                </div>

                                <!-- Subir imágenes -->
                                <div class="border border-gray-200 rounded p-6 space-y-4 shadow-sm">
                                    <div>
                                        <h3 class="text-xl font-bold text-gray-900">Subir imágenes</h3>
                                        <p class="text-sm text-gray-500 mt-1">Sube imágenes individuales o una carpeta completa (PNG, JPG, JPEG).</p>
                                    </div>

                                    <!-- Toggle archivos / carpeta -->
                                    <div class="flex gap-2">
                                        <button type="button" id="btnModoArchivos"
                                            class="flex-1 py-1.5 text-xs font-semibold rounded border border-blue-600 bg-blue-600 text-white transition-all"
                                            onclick="setModoImg('archivos')">
                                            Archivos
                                        </button>
                                        <button type="button" id="btnModoCarpeta"
                                            class="flex-1 py-1.5 text-xs font-semibold rounded border border-gray-300 bg-white text-gray-600 hover:border-blue-600 transition-all"
                                            onclick="setModoImg('carpeta')">
                                            Carpeta
                                        </button>
                                    </div>

                                    <label id="imgDropZone"
                                        class="flex flex-col items-center justify-center gap-2 p-10 border-2 border-dashed border-gray-300 rounded shadow-sm cursor-pointer hover:border-blue-600 hover:bg-blue-50 transition-all"
                                        for="imagenesInput">
                                        <svg id="imgIcon" class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                        </svg>
                                        <span id="imgLabel" class="text-sm text-gray-600 font-medium text-center">Haz clic o arrastra tus imágenes aquí</span>
                                        <span id="imgSubLabel" class="text-xs text-gray-400">Archivos individuales seleccionados</span>
                                        <input id="imagenesInput" name="imagenes" type="file" accept="image/png,image/jpg,image/jpeg" multiple hidden />
                                    </label>
                                </div>

                            </div>

                            <button type="submit"
                                class="w-full mt-6 py-3 bg-blue-600 text-white font-bold text-sm rounded hover:bg-blue-700 transition-colors">
                                Subir archivos al catálogo
                            </button>
                        </form>
                    </div>

                </div><!-- /card -->
            </div>
        </main>
    </div>

    <%- include('partials/footer.ejs') %>

    <!-- Modal de Confirmación -->
    <div id="confirmModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
        <div class="bg-white rounded shadow-xl p-8 max-w-md mx-auto w-full">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Confirmar información</h2>
            <p class="text-gray-600 mb-8">¿Estás seguro de la información de este producto?</p>
            <div class="flex gap-4">
                <button id="cancelBtn" type="button"
                    class="flex-1 py-3 px-4 border-2 border-gray-300 text-gray-900 font-bold rounded hover:border-gray-400 transition-all">
                    Cancelar
                </button>
                <button id="continueBtn" type="button"
                    class="flex-1 py-3 px-4 bg-blue-600 text-white font-bold rounded hover:bg-blue-700 transition-all">
                    Continuar
                </button>
            </div>
        </div>
    </div>

    <!-- Modal de Resultado -->
    <div id="resultModal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
        <div class="bg-white rounded shadow-xl p-8 max-w-md mx-auto w-full">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">¡Éxito!</h2>
            <p id="resultMessage" class="text-gray-600 mb-8"></p>
            <button id="closeResultBtn" type="button"
                class="w-full py-3 px-4 bg-blue-600 text-white font-bold rounded hover:bg-blue-700 transition-all">
                Cerrar
            </button>
        </div>
    </div>

    <script>
        // Tab switch
        const productTabs   = document.querySelectorAll('[data-product-tab]');
        const productPanels = document.querySelectorAll('[data-product-panel]');

        productTabs.forEach(tab => {
            tab.addEventListener('click', () => {
                const target = tab.dataset.productTab;
                productTabs.forEach(t => {
                    t.classList.toggle('border-b-blue-600',   t === tab);
                    t.classList.toggle('border-b-transparent', t !== tab);
                    t.classList.toggle('text-gray-900', t === tab);
                    t.classList.toggle('text-gray-500', t !== tab);
                });
                productPanels.forEach(p => p.classList.toggle('hidden', p.dataset.productPanel !== target));
            });
        });

        // Campaign → activo toggle rule
        const campaniaSelect  = document.getElementById('campania');
        const activeToggle    = document.getElementById('activeToggle');
        const activeToggleLbl = document.getElementById('activeToggleLabel');
        const activoWarning   = document.getElementById('activoWarning');

        function applyCampaniaRule() {
            const selected = campaniaSelect.options[campaniaSelect.selectedIndex];
            const campanaActiva = selected?.dataset.activo === 'true';
            if (!campanaActiva) {
                activeToggle.checked = false;
                activeToggle.disabled = true;
                activeToggleLbl.classList.add('opacity-40', 'cursor-not-allowed');
                activoWarning.classList.remove('hidden');
            } else {
                activeToggle.disabled = false;
                activeToggleLbl.classList.remove('opacity-40', 'cursor-not-allowed');
                activoWarning.classList.add('hidden');
            }
        }

        campaniaSelect.addEventListener('change', applyCampaniaRule);
        applyCampaniaRule(); // apply on page load in case form was repopulated

        // Confirm modal
        const form         = document.querySelector('form');
        const submitBtn    = document.getElementById('submitBtn');
        const confirmModal = document.getElementById('confirmModal');
        const cancelBtn    = document.getElementById('cancelBtn');
        const continueBtn  = document.getElementById('continueBtn');

        submitBtn.addEventListener('click', () => {
            const nombre       = document.getElementById('productName').value.trim();
            const descripcion  = document.getElementById('productDescription').value.trim();
            const clave        = document.getElementById('productKey').value.trim();
            const unidad_venta = document.getElementById('saleUnit').value;
            const unidad_medida= document.getElementById('measureUnit').value;
            const imagen       = document.getElementById('productImage').files[0];
            const imagenTemp   = document.querySelector('input[name="imagen_temp"]')?.value;
            const precio       = document.getElementById('productPrice').value.trim();
            const peso         = document.getElementById('productWeight').value.trim();

            if (!nombre || !descripcion || !clave || !unidad_venta || !unidad_medida || (!imagen && !imagenTemp) || !precio || !peso) {
                alert('Por favor, llena todos los campos correctamente.');
                return;
            }
            confirmModal.classList.remove('hidden');
        });

        cancelBtn.addEventListener('click',   () => confirmModal.classList.add('hidden'));
        continueBtn.addEventListener('click', () => { confirmModal.classList.add('hidden'); form.submit(); });

        // Result modal
        <% if (mensaje) { %>
            const resultModal    = document.getElementById('resultModal');
            const resultMessage  = document.getElementById('resultMessage');
            const closeResultBtn = document.getElementById('closeResultBtn');
            resultMessage.textContent = '<%= mensaje.activo ? "El producto se agregó correctamente" : "El producto se agregó como INACTIVO y no se mostrará" %>';
            resultModal.classList.remove('hidden');
            closeResultBtn.addEventListener('click', () => { window.location.href = '/admin/home'; });
        <% } %>

        // Auto-open bulk tab if came from bulk action
        <% if (mensajeBulk || errorBulk || resultadoCSV) { %>
            document.querySelector('[data-product-tab="bulk"]')?.click();
        <% } %>

        // CSV filename preview
        document.getElementById('bulkFile')?.addEventListener('change', function () {
            if (this.files.length) document.getElementById('csvLabel').textContent = this.files[0].name;
        });

        // Image upload preview
        document.getElementById('productImage')?.addEventListener('change', function () {
            const file = this.files[0];
            if (!file) return;
            const preview = document.getElementById('imagePreview');
            preview.src = URL.createObjectURL(file);
            preview.classList.remove('hidden');
            document.getElementById('imageUploadText').textContent = file.name;
            const lbl = document.getElementById('imageUploadLabel');
            lbl.classList.remove('border-gray-300');
            lbl.classList.add('border-green-500', 'bg-green-50');
        });

        // Bulk images — modo archivos / carpeta
        function setModoImg(modo) {
            const input    = document.getElementById('imagenesInput');
            const btnArch  = document.getElementById('btnModoArchivos');
            const btnCarp  = document.getElementById('btnModoCarpeta');
            const subLabel = document.getElementById('imgSubLabel');

            // Resetear input para evitar que queden archivos del modo anterior
            input.value = '';
            document.getElementById('imgLabel').textContent = 'Haz clic o arrastra tus imágenes aquí';
            document.getElementById('imgDropZone').classList.remove('border-blue-500', 'bg-blue-50');
            document.getElementById('imgDropZone').classList.add('border-gray-300');

            if (modo === 'carpeta') {
                input.setAttribute('webkitdirectory', '');
                input.removeAttribute('multiple');
                subLabel.textContent = 'Carpeta completa seleccionada';
                btnCarp.classList.add('bg-blue-600', 'text-white', 'border-blue-600');
                btnCarp.classList.remove('bg-white', 'text-gray-600', 'border-gray-300');
                btnArch.classList.add('bg-white', 'text-gray-600', 'border-gray-300');
                btnArch.classList.remove('bg-blue-600', 'text-white', 'border-blue-600');
            } else {
                input.removeAttribute('webkitdirectory');
                input.setAttribute('multiple', '');
                subLabel.textContent = 'Archivos individuales seleccionados';
                btnArch.classList.add('bg-blue-600', 'text-white', 'border-blue-600');
                btnArch.classList.remove('bg-white', 'text-gray-600', 'border-gray-300');
                btnCarp.classList.add('bg-white', 'text-gray-600', 'border-gray-300');
                btnCarp.classList.remove('bg-blue-600', 'text-white', 'border-blue-600');
            }
        }

        document.getElementById('imagenesInput')?.addEventListener('change', function () {
            const count    = this.files.length;
            const lbl      = document.getElementById('imgLabel');
            const dropZone = document.getElementById('imgDropZone');

            if (count === 0) {
                lbl.textContent = 'Haz clic o arrastra tus imágenes aquí';
                dropZone.classList.remove('border-blue-500', 'bg-blue-50');
                dropZone.classList.add('border-gray-300');
            } else {
                const esCarpeta = this.hasAttribute('webkitdirectory');
                if (esCarpeta) {
                    const carpeta = this.files[0].webkitRelativePath.split('/')[0];
                    lbl.textContent = `📁 ${carpeta} — ${count} imagen${count !== 1 ? 'es' : ''}`;
                } else {
                    lbl.textContent = count === 1 ? this.files[0].name : `${count} imágenes seleccionadas`;
                }
                dropZone.classList.remove('border-gray-300');
                dropZone.classList.add('border-blue-500', 'bg-blue-50');
            }
        });
    </script>

</body>
</html>
