<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Bitácora de actividades</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Public Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
    </style>
</head>

<body class="bg-blue-50">
    <%- include('partials/header.ejs') %>

    <div class="flex min-h-screen flex-col">
        <%- include('partials/sidebar.ejs') %>

        <main class="ml-48 pt-2 px-10 pb-9 flex-1">
            <section class="space-y-6">

                <!-- Título y badge de fecha -->
                <div class="flex items-center justify-between">
                    <h1 class="text-3xl font-extrabold text-gray-900">Bitácora de actividades</h1>
                    <% if (!searchQuery && !id_usuario_filtro) { %>
                        <span class="text-xs font-semibold text-blue-700 bg-blue-100 border border-blue-200 px-3 py-1 rounded-full">
                            Bitácora desde el <%= fechaDesde %>
                        </span>
                    <% } %>
                </div>

                <!-- Buscador de admins -->
                <form method="GET" action="/admin/bitacora" class="flex items-center gap-3">
                    <div class="flex-1 relative">
                        <input
                            type="text"
                            name="search"
                            value="<%= searchQuery %>"
                            placeholder="Buscar administrador por nombre o email"
                            class="w-full px-5 py-2.5 border-2 border-gray-300 rounded text-sm font-medium focus:border-blue-600 focus:outline-none transition-colors"
                        />
                    </div>
                    <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded font-semibold text-sm hover:bg-blue-700 transition-all">
                        Buscar
                    </button>
                    <% if (searchQuery || id_usuario_filtro) { %>
                        <a href="/admin/bitacora" class="px-6 py-2.5 bg-white border-2 border-gray-300 rounded font-semibold text-sm text-gray-700 hover:bg-gray-100 transition-all">
                            Ver todo
                        </a>
                    <% } %>
                </form>

                <!-- Error de búsqueda -->
                <% if (errorBusqueda) { %>
                    <div class="bg-red-50 border border-red-200 text-red-700 text-sm font-medium px-5 py-3 rounded">
                        <%= errorBusqueda %>
                    </div>
                <% } %>

                <!-- Resultados de búsqueda: lista de admins -->
                <% if (admins.length > 0) { %>
                    <div class="bg-white border border-gray-200 overflow-hidden">
                        <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
                            <p class="text-sm font-semibold text-gray-600">
                                <%= admins.length %> administrador<%= admins.length !== 1 ? 'es' : '' %> encontrado<%= admins.length !== 1 ? 's' : '' %>
                            </p>
                        </div>
                        <div class="divide-y divide-gray-100">
                            <% admins.forEach(admin => { %>
                                <a href="/admin/bitacora?id_usuario=<%= admin.id_usuario %>&search=<%= encodeURIComponent(searchQuery) %>"
                                   class="flex items-center gap-4 px-6 py-4 hover:bg-blue-50 transition-colors">
                                    <div class="w-9 h-9 rounded-full bg-gray-200 flex items-center justify-center flex-shrink-0">
                                        <img src="/img/iconoPerfil.png" alt="Admin" class="w-full h-full object-cover rounded-full">
                                    </div>
                                    <div>
                                        <p class="font-semibold text-gray-900 text-sm">
                                            <%= admin.Nombre_usuario || admin.email %>
                                        </p>
                                        <% if (admin.Nombre_usuario) { %>
                                            <p class="text-gray-500 text-xs"><%= admin.email %></p>
                                        <% } %>
                                    </div>
                                    <svg class="ml-auto w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </a>
                            <% }) %>
                        </div>
                    </div>
                <% } %>

                <!-- Header cuando se ve a un admin específico -->
                <% if (adminSeleccionado) { %>
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-full bg-gray-200 overflow-hidden flex-shrink-0">
                            <img src="/img/iconoPerfil.png" alt="Admin" class="w-full h-full object-cover">
                        </div>
                        <div>
                            <p class="font-bold text-gray-900">
                                <%= adminSeleccionado.Nombre_usuario || adminSeleccionado.email %>
                            </p>
                            <% if (adminSeleccionado.Nombre_usuario) { %>
                                <p class="text-gray-500 text-xs"><%= adminSeleccionado.email %></p>
                            <% } %>
                        </div>
                        <span class="ml-2 text-xs text-gray-500 font-medium">— Actividad de la última semana</span>
                    </div>
                <% } %>

                <!-- Tabla de logs -->
                <% if (logs.length > 0) { %>
                    <div class="bg-white border border-gray-200 overflow-hidden">
                        <!-- Encabezado de tabla -->
                        <div class="grid grid-cols-3 gap-4 px-6 py-4 border-b-2 border-gray-300 bg-gray-100">
                            <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Administrador</span>
                            <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Acción</span>
                            <span class="font-bold text-sm text-gray-700 uppercase tracking-wide">Fecha y hora</span>
                        </div>
                        <!-- Filas -->
                        <div class="divide-y divide-gray-100">
                            <% logs.forEach(log => { %>
                                <div class="grid grid-cols-3 gap-4 px-6 py-4 items-center">
                                    <span class="font-semibold text-gray-800 text-sm">
                                        <%= log.usuario?.Nombre_usuario || log.usuario?.email || `Admin #${log.id_usuario}` %>
                                    </span>
                                    <span class="text-gray-700 text-sm"><%= log.accion %></span>
                                    <span class="text-gray-500 text-sm">
                                        <%= new Date(log.time).toLocaleString('es-MX', {
                                            timeZone: 'America/Mexico_City',
                                            day: '2-digit',
                                            month: '2-digit',
                                            year: '2-digit',
                                            hour: '2-digit',
                                            minute: '2-digit'
                                        }) %>
                                    </span>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                <% } %>

                <!-- Estado vacío -->
                <% if (mensaje && logs.length === 0 && admins.length === 0) { %>
                    <div class="bg-white border border-gray-200 px-6 py-12 text-center">
                        <p class="text-gray-400 text-sm font-medium"><%= mensaje %></p>
                    </div>
                <% } %>

            </section>
        </main>
    </div>

    <%- include('partials/footer.ejs') %>
</body>
</html>
