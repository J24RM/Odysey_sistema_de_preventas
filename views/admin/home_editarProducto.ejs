<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Editar Producto</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Public Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-50">

    <%- include('partials/header.ejs') %>

    <div class="flex min-h-screen flex-col">
        <%- include('partials/sidebar.ejs') %>

        <!-- Main Content -->
        <main class="ml-48 pt-2 px-10 pb-9 flex-1">
            <!-- Back Button -->
            <a href="/admin/home" class="inline-flex items-center gap-2 text-blue-600 font-semibold hover:text-blue-700 transition-colors mb-8">
                <span>←</span>
                <span>Volver al inicio</span>
            </a>

            <!-- Page Title -->
            <h1 class="text-4xl font-extrabold text-gray-900 mb-10">Editar producto</h1>

            <!-- Search Section -->
            <div class="bg-white rounded-2xl shadow-md p-8 mb-8">
                <div class="flex gap-4">
                    <input type="text" placeholder="Busca producto por nombre o clave" class="flex-1 px-5 py-3 border-2 border-gray-300 rounded-full text-sm font-medium focus:border-blue-600 focus:outline-none transition-colors" />
                    <button type="button" aria-label="Buscar producto" class="px-8 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-all">
                        Buscar
                    </button>
                </div>
            </div>

            <!-- Products Section -->
            <div>
                <h2 class="text-2xl font-bold text-gray-900 mb-6">Selecciona el producto a editar</h2>

                <div class="grid grid-cols-1 gap-4">
                    <% for (let i = 0; i < 6; i++) { %>
                        <article class="bg-white rounded-xl p-6 border-2 border-gray-200 hover:border-blue-500 hover:bg-blue-50 transition-all shadow-sm hover:shadow-md flex gap-6">
                            <div class="flex-shrink-0 w-28 h-28 rounded-lg bg-gray-100 flex items-center justify-center">
                                <img src="/img/botePintura.png" alt="Sellador Comex" class="max-h-24 max-w-full object-contain">
                            </div>
                            <div class="flex-1 flex flex-col justify-between">
                                <p class="text-base font-semibold text-gray-900">
                                    Sellador Comex 5×1 Clásico Preparación de Superficies PPG Silicona o Poliuretano 4000 ml
                                </p>
                                <button type="button" class="self-start px-6 py-2.5 bg-blue-600 text-white font-bold text-sm rounded-lg hover:bg-blue-700 transition-all">
                                    Editar producto
                                </button>
                            </div>
                        </article>
                    <% } %>
                </div>
            </div>
        </main>
    </div>

    <%- include('partials/footer.ejs') %>

</body>
</html>